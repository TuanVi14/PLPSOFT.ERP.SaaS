@model PLPSOFT.ERP.WebApp.Models.ProductUnitViewModel

@{
    ViewData["Title"] = "Chỉnh sửa đơn vị tính";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">

    <!-- Header -->
    <div class="page-header">
        <h1 class="page-title">Chỉnh sửa đơn vị tính</h1>

        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Đơn vị tính</a></li>
            <li class="breadcrumb-item active">@Model.UnitName</li>
        </ol>
    </div>

    <!-- Card -->
    <div class="card form-card">
        <div class="card-header">
            <i class="bi bi-pencil-square me-1"></i>
            Thông tin đơn vị tính
        </div>

        <div class="card-body">
            <form asp-action="Edit" class="form-standard">

                <input type="hidden" asp-for="UnitID" />

                <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

                <div class="row g-3">

                    <!-- LEFT -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Mã đơn vị</label>
                            <input asp-for="UnitCode" class="form-control" />
                            <span asp-validation-for="UnitCode" class="form-error"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Tên đơn vị</label>
                            <input asp-for="UnitName" class="form-control" />
                            <span asp-validation-for="UnitName" class="form-error"></span>
                        </div>
                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Nhóm/Loại đơn vị</label>
                            <select asp-for="UnitTypeID"
                                    class="form-select"
                                    asp-items="Model.UnitTypeOptions">
                                <option value="">-- Chọn loại đơn vị --</option>
                            </select>
                            <span asp-validation-for="UnitTypeID" class="form-error"></span>
                        </div>

                        <div class="form-group mt-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input"
                                       asp-for="IsActive"
                                       type="checkbox" />
                                <label class="form-check-label">
                                    Hoạt động
                                </label>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left"></i>
                        Quay lại
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i>
                        Cập nhật
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}