@model PLPSOFT.ERP.Domain.Entities.MasterData.ProductUnit

@{
    ViewData["Title"] = "Sửa đơn vị tính";
}

<div class="container mt-4">
    <h3>Sửa đơn vị tính</h3>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="ProductUnitID" />
        <div class="mb-3">
            <label>Loại đơn vị</label>
            <select asp-for="UnitTypeID" class="form-control" asp-items="ViewBag.UnitTypeID">
                <option value="">-- Chọn loại đơn vị --</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Mã đơn vị</label>
            <input asp-for="UnitCode" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Tên đơn vị</label>
            <input asp-for="UnitName" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Cập nhật</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>