@model PLPSOFT.ERP.WebApp.Models.ProductUnitViewModel

@{
    ViewData["Title"] = "Thêm mới đơn vị tính";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-rulers text-primary me-2"></i>
        Thêm mới đơn vị tính
        <small>Nhập thông tin đơn vị đo lường</small>
    </h1>
</div>

<form asp-action="Create">

    <!-- FORM CARD -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-balance-scale"></i> Thông tin đơn vị tính
            </h2>
        </div>

        <div class="plp-card-body">
            <div class="row g-3">

                <!-- LEFT -->
                <div class="col-md-6">

                    <div>
                        <label class="plp-form-label">Mã đơn vị</label>
                        <input asp-for="UnitCode"
                               class="form-control"
                               placeholder="VD: PCS, KG, THUNG..." />
                        <span asp-validation-for="UnitCode" class="text-danger small"></span>
                    </div>

                    <div>
                        <label class="plp-form-label">Tên đơn vị</label>
                        <input asp-for="UnitName"
                               class="form-control"
                               placeholder="VD: Cái, Kilogram, Thùng..." />
                        <span asp-validation-for="UnitName" class="text-danger small"></span>
                    </div>

                </div>

                <!-- RIGHT -->
                <div class="col-md-6">

                    <div>
                        <label class="plp-form-label">Nhóm/Loại đơn vị</label>
                        <select asp-for="UnitTypeID"
                                class="form-select"
                                asp-items="Model.UnitTypeOptions">
                            <option value="">-- Chọn loại (Số lượng/Khối lượng...) --</option>
                        </select>
                        <span asp-validation-for="UnitTypeID" class="text-danger small"></span>
                    </div>

                    <div class="mt-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input"
                                   asp-for="IsActive"
                                   type="checkbox" />
                            <label class="form-check-label">
                                Hoạt động
                            </label>
                        </div>
                    </div>

                </div>

            </div>

            <!-- ACTIONS -->
            <div class="plp-form-actions">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>

                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-check-lg"></i> Lưu đơn vị
                </button>
            </div>

        </div>
    </div>

</form>