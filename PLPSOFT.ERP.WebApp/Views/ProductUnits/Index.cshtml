@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.ProductUnit>

@{
    ViewData["Title"] = "Đơn vị tính";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.AntiForgeryToken()

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-rulers text-primary me-2"></i>
        Đơn vị tính
        <small>Danh sách đơn vị đo lường trong hệ thống</small>
    </h1>

    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Thêm đơn vị mới
    </a>
</div>

<!-- FILTER BAR -->
<div class="plp-filter-bar">
    <form asp-action="Index" method="get">
        <div class="row g-2">
            <div class="col-md-8">
                <div class="plp-search-group">
                    <i class="bi bi-search plp-search-icon"></i>
                    <input type="text"
                           name="searchString"
                           class="form-control plp-search-input"
                           placeholder="Tìm tên hoặc mã đơn vị..."
                           value="@ViewData["CurrentFilter"]" />
                </div>
            </div>

            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-search"></i> Tìm
                </button>

                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                }
            </div>
        </div>
    </form>
</div>

<!-- TABLE CARD -->
<div class="plp-card">
    <div class="plp-card-header">
        <h2 class="plp-card-title">
            <i class="bi bi-table"></i> Danh sách đơn vị tính
        </h2>
    </div>

    <div class="plp-table-wrap">
        <table class="plp-table">
            <thead>
                <tr>
                    <th class="col-center" style="width:120px;">Mã</th>
                    <th>Tên đơn vị</th>
                    <th>Loại đơn vị</th>
                    <th class="col-center">Trạng thái</th>
                    <th class="col-actions" style="width:160px;">Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            Không có dữ liệu
                        </td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    <tr class="@(!item.IsActive ? "row-inactive" : "")">
                        <td class="col-center">
                            <span class="plp-code">@item.UnitCode</span>
                        </td>

                        <td>@item.UnitName</td>

                        <td>
                            <span class="plp-badge plp-badge-info">
                                @item.UnitType?.ValueName
                            </span>
                        </td>

                        <td class="col-center">
                            @if (item.IsActive)
                            {
                                <span class="plp-badge plp-badge-success">
                                    <i class="bi bi-check-circle-fill"></i> Hoạt động
                                </span>
                            }
                            else
                            {
                                <span class="plp-badge plp-badge-muted">
                                    <i class="bi bi-slash-circle"></i> Ngừng
                                </span>
                            }
                        </td>

                        <td class="col-actions">
                            <div class="d-flex justify-content-center gap-1">
                                @if (item.IsActive)
                                {
                                    <a asp-action="Edit"
                                       asp-route-id="@item.UnitId"
                                       class="btn btn-sm btn-outline-warning"
                                       title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            title="Ngừng sử dụng"
                                            onclick="confirmDelete(@item.UnitId)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-success"
                                            title="Phục hồi"
                                            onclick="restoreUnit(@item.UnitId)">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (!confirm("Xác nhận ngừng sử dụng đơn vị này?")) return;

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('@Url.Action("Delete", "ProductUnits")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}&__RequestVerificationToken=${token}`
            })
            .then(res => res.json())
            .then(data => {
                alert(data.message || "Thao tác hoàn tất");
                if (data.success) location.reload();
            })
            .catch(() => alert("Lỗi hệ thống."));
        }

        function restoreUnit(id) {
            if (!confirm("Bạn muốn phục hồi đơn vị này về trạng thái hoạt động?")) return;

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('@Url.Action("Restore", "ProductUnits")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}&__RequestVerificationToken=${token}`
            })
            .then(res => res.json())
            .then(data => {
                alert(data.message || "Phục hồi thành công");
                if (data.success) location.reload();
            })
            .catch(() => alert("Lỗi hệ thống."));
        }
    </script>
}