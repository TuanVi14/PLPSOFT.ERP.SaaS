@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.ProductUnit>

@{
    ViewData["Title"] = "Đơn vị tính";
}

<div class="container mt-4">
    <h3>Đơn vị tính</h3>

    <a asp-action="Create" class="btn btn-primary mb-3">+ Thêm mới</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Mã đơn vị</th>
                <th>Tên đơn vị</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.UnitCode</td>
                    <td>@item.UnitName</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.ProductUnitID" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.ProductUnitID" class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>