@model PLPSOFT.ERP.Domain.Entities.MasterData.SupplierGroup

@{
    ViewData["Title"] = "Sửa nhóm nhà cung cấp";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="bi bi-pencil-square me-2"></i>
                Sửa nhóm nhà cung cấp
            </h1>

            <div class="page-subtitle">
                Cập nhật thông tin nhóm nhà cung cấp
            </div>
        </div>

        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Nhóm nhà cung cấp</a></li>
            <li class="breadcrumb-item active">Sửa</li>
        </ol>
    </div>

    <!-- FORM -->
    <div class="card form-card">
        <div class="card-header">
            <i class="bi bi-info-circle me-1"></i>
            Thông tin nhóm
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post" class="form-standard">

                <input type="hidden" asp-for="SupplierGroupId" />

                <!-- Validation -->
                <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

                <div class="row g-3">

                    <!-- Mã nhóm -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Mã nhóm</label>
                            <input asp-for="GroupCode"
                                   class="form-control"
                                   placeholder="Nhập mã nhóm..." />
                            <span asp-validation-for="GroupCode" class="form-error"></span>
                        </div>
                    </div>

                    <!-- Tên nhóm -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Tên nhóm</label>
                            <input asp-for="GroupName"
                                   class="form-control"
                                   placeholder="Nhập tên nhóm..." />
                            <span asp-validation-for="GroupName" class="form-error"></span>
                        </div>
                    </div>

                    <!-- Công ty -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Công ty</label>
                            <select asp-for="CompanyId" class="form-select">
                                <option value="">-- Chọn công ty --</option>
                                @foreach (var item in ViewBag.Companies)
                                {
                                    <option value="@item.CompanyId">
                                        @item.CompanyName
                                    </option>
                                }
                            </select>
                        </div>
                    </div>

                </div>

                <!-- ACTION -->
                <div class="form-actions">
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left"></i>
                        Quay lại
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i>
                        Lưu
                    </button>
                </div>

            </form>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}