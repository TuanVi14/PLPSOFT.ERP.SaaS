@model List<PLPSOFT.ERP.Domain.Entities.MasterData.SupplierGroup>

@{
    ViewData["Title"] = "Nhóm nhà cung cấp";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="plp-page-header">
        <div>
            <h1 class="page-title">
                <i class="bi bi-diagram-3 me-2"></i>
                Nhóm nhà cung cấp
            </h1>
            <div class="page-subtitle">
                Quản lý nhóm NCC
            </div>
        </div>

        <div class="page-actions">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i>
                Thêm mới
            </a>
        </div>
    </div>

    <!-- FILTER -->
    <div class="card filter-card">
        <div class="card-body">
            <form method="get" class="filter-form">
                <div class="row g-3 align-items-center">

                    <div class="col-md-8">
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-search"></i>
                            </span>

                            <input type="text"
                                   name="search"
                                   value="@ViewBag.Search"
                                   class="form-control"
                                   placeholder="Tìm tên nhóm..." />
                        </div>
                    </div>

                    <div class="col-md-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i>
                            Tìm
                        </button>

                        @if (!string.IsNullOrEmpty(ViewBag.Search))
                        {
                            <a asp-action="Index" class="btn btn-light">
                                <i class="bi bi-arrow-clockwise"></i>
                            </a>
                        }
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- EMPTY -->
    @if (!Model.Any())
    {
        <div class="card">
            <div class="empty-state">
                <i class="bi bi-diagram-3"></i>
                <p>Chưa có nhóm nhà cung cấp nào</p>
            </div>
        </div>
    }
    else
    {
        <!-- TABLE -->
        <div class="card table-card">

            <div class="card-header">
                <span class="table-title">
                    <i class="bi bi-table me-1"></i>
                    Danh sách
                </span>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-system align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width:120px;">Mã</th>
                                <th>Tên</th>
                                <th>Công ty</th>
                                <th class="text-center" style="width:150px;">Trạng thái</th>
                                <th class="text-center" style="width:160px;">Hành động</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="@(item.IsActive ? "" : "row-inactive")">

                                    <!-- CODE -->
                                    <td>
                                        <span class="text-primary fw-semibold">
                                            @item.GroupCode
                                        </span>
                                    </td>

                                    <!-- NAME -->
                                    <td class="fw-medium">
                                        @item.GroupName
                                    </td>

                                    <!-- COMPANY -->
                                    <td>
                                        @item.Company?.CompanyName
                                    </td>

                                    <!-- STATUS -->
                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge badge-success">
                                                <i class="bi bi-check-circle me-1"></i>
                                                Hoạt động
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">
                                                <i class="bi bi-slash-circle me-1"></i>
                                                Ngừng
                                            </span>
                                        }
                                    </td>

                                    <!-- ACTION -->
                                    <td class="text-center">
                                        <div class="action-group">

                                            <!-- EDIT -->
                                            <a asp-action="Edit"
                                               asp-route-id="@item.SupplierGroupId"
                                               class="btn btn-sm btn-outline-warning">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            @if (item.IsActive)
                                            {
                                                <!-- DELETE -->
                                                <a asp-action="Delete"
                                                   asp-route-id="@item.SupplierGroupId"
                                                   class="btn btn-sm btn-outline-danger"
                                                   onclick="return confirm('Bạn có chắc muốn xóa?')">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <!-- RESTORE -->
                                                <a asp-action="Restore"
                                                   asp-route-id="@item.SupplierGroupId"
                                                   class="btn btn-sm btn-outline-success">
                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                </a>
                                            }

                                        </div>
                                    </td>

                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    }

</div>