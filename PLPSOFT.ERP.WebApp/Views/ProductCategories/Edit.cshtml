@model PLPSOFT.ERP.WebApp.Models.CategoryViewModel

@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
}

<!-- HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-pencil-square text-primary me-2"></i>
        Chỉnh sửa danh mục
        <small>@Model.CategoryName</small>
    </h1>

    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Edit" method="post">

    <!-- VALIDATION -->
    <div asp-validation-summary="ModelOnly" class="plp-alert plp-alert-danger"></div>

    <input type="hidden" asp-for="CategoryID" />
    <input type="hidden" asp-for="CompanyID" />

    <!-- CARD -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-diagram-3"></i> Thông tin danh mục
            </h2>
        </div>

        <div class="plp-card-body">
            <div class="row g-3">

                <!-- LEFT -->
                <div class="col-md-6">

                    <div>
                        <label class="plp-form-label">Công ty</label>
                        <select class="form-select"
                                onchange="window.location.href='?id=@Model.CategoryID&companyId=' + this.value">
                            <option value="0">-- Chọn công ty --</option>
                            @foreach (var c in Model.Companies)
                            {
                                <option value="@c.Value"
                                        selected="@(c.Value == Model.CompanyID.ToString() ? "selected" : null)">
                                    @c.Text
                                </option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="plp-form-label">Danh mục cha</label>
                        <select asp-for="ParentID"
                                class="form-select"
                                asp-items="Model.ParentCategories">
                            <option value="">-- Cấp cao nhất --</option>
                        </select>
                    </div>

                </div>

                <!-- RIGHT -->
                <div class="col-md-6">

                    <div>
                        <label class="plp-form-label">Mã danh mục</label>
                        <input asp-for="CategoryCode" class="form-control" />
                    </div>

                    <div>
                        <label class="plp-form-label">Tên danh mục</label>
                        <input asp-for="CategoryName" class="form-control" />
                    </div>

                    <div class="form-check mt-3">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label">Hoạt động</label>
                    </div>

                </div>

            </div>
        </div>
    </div>

    <!-- ACTION -->
    <div class="plp-form-actions">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>

        <button type="submit" class="btn btn-primary btn-lg">
            <i class="bi bi-check-lg"></i> Lưu
        </button>
    </div>

</form>