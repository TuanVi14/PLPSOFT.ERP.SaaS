@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.ProductCategory>

@{
    ViewData["Title"] = "Danh mục Sản phẩm";
}

@Html.AntiForgeryToken()

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-diagram-3 me-2"></i>
            Danh mục sản phẩm
        </h1>

        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
            </li>
            <li class="breadcrumb-item active">Danh mục</li>
        </ol>
    </div>

    <!-- ACTION -->
    <div class="mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">

        <!-- SEARCH -->
        <form asp-action="Index" method="get" class="plp-input-group" style="max-width:350px">
            <input type="text"
                   name="searchString"
                   value="@ViewData["CurrentFilter"]"
                   class="plp-input"
                   placeholder="Tìm tên hoặc mã danh mục..." />

            <button type="submit" class="plp-btn plp-btn-secondary">
                <i class="bi bi-search"></i>
            </button>

            @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
            {
                <a asp-action="Index" class="plp-btn plp-btn-outline">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
            }
        </form>

        <!-- CREATE BUTTON -->
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            Thêm danh mục mới
        </a>

    </div>

    <!-- CARD -->
    <div class="card table-card">

        <!-- HEADER -->
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                <i class="bi bi-info-circle me-1"></i>
                Cấu trúc phân loại hàng hóa
            </span>
        </div>

        <!-- BODY -->
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width:120px">Mã</th>
                            <th>Tên danh mục</th>
                            <th style="width:180px">Công ty</th>
                            <th>Danh mục cha</th>
                            <th class="text-center" style="width:140px">Trạng thái</th>
                            <th class="text-center" style="width:160px">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    Không có dữ liệu
                                </td>
                            </tr>
                        }

                        @foreach (var item in Model)
                        {
                            <tr class="@(item.IsActive ? "" : "row-disabled")">

                                <td class="text-center fw-semibold text-primary">
                                    @item.CategoryCode
                                </td>

                                <td>@item.CategoryName</td>

                                <td class="text-muted">
                                    @item.Company?.ShortName
                                </td>

                                <td>
                                    @if (item.Parent != null)
                                    {
                                        <span class="text-muted">
                                            <i class="bi bi-arrow-return-right me-1"></i>
                                            @item.Parent.CategoryName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">---</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            Hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            Ngừng
                                        </span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex justify-content-center gap-2">

                                        @if (item.IsActive)
                                        {
                                            <a asp-action="Edit"
                                               asp-route-id="@item.CategoryId"
                                               class="btn btn-warning btn-sm"
                                               title="Sửa">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <button type="button"
                                                    class="btn btn-danger btn-sm"
                                                    title="Ngừng sử dụng"
                                                    onclick="confirmDelete(@item.CategoryId)">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-success btn-sm"
                                                    title="Kích hoạt lại"
                                                    onclick="restoreCategory(@item.CategoryId)">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        }

                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm("Xác nhận ngừng dùng danh mục này?")) {
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.post('/ProductCategories/Delete/' + id,
                    { __RequestVerificationToken: token },
                    function (res) {
                        if (res.success) location.reload();
                        else alert(res.message);
                    });
            }
        }

        function restoreCategory(id) {
            if (confirm("Kích hoạt lại danh mục này?")) {
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.post('/ProductCategories/Restore/' + id,
                    { __RequestVerificationToken: token },
                    function (res) {
                        if (res.success) location.reload();
                        else alert(res.message);
                    });
            }
        }
    </script>
}

<style>
    .row-disabled {
        opacity: 0.5;
    }
</style>