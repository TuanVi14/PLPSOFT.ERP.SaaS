@model IEnumerable<PLPSOFT.ERP.WebApp.Models.CategoryViewModel>

@{
    ViewData["Title"] = "Danh mục sản phẩm";
}

<div class="container mt-4">
    <h3>Danh mục sản phẩm</h3>

    <a asp-action="Create" class="btn btn-primary mb-3">+ Thêm mới</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Mã</th>
                <th>Tên danh mục</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CategoryCode</td>
                    <td>@item.CategoryName</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.CategoryID" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.CategoryID" class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>