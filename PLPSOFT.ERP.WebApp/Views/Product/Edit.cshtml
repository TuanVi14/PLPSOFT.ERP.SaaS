@model PLPSOFT.ERP.WebApp.Models.ProductViewModel

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">@ViewData["Title"]</h1>

    <!-- Breadcrumb -->
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Sản phẩm</a></li>
        <li class="breadcrumb-item active">@Model.ProductName</li>
    </ol>

    <div class="card shadow-sm">
        <!-- HEADER -->
        <div class="card-header bg-light">
            <i class="fas fa-edit me-1"></i>
            <span class="fw-bold">Thông tin sản phẩm</span>
        </div>

        <!-- BODY -->
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="ProductID" />

                <div class="row">

                    <!-- LEFT -->
                    <div class="col-md-6">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Công ty</label>
                            <select asp-for="CompanyID" class="form-select" asp-items="Model.Companies"></select>
                            <span asp-validation-for="CompanyID" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mã sản phẩm</label>
                            <input asp-for="ProductCode" class="form-control" readonly style="background-color: #e9ecef;" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tên sản phẩm</label>
                            <input asp-for="ProductName" class="form-control" />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>

                        <div class="mb-3 d-flex align-items-center">
                            <div class="form-check mt-3">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" />
                                <label class="form-check-label fw-semibold">
                                    Hoạt động
                                </label>
                            </div>
                        </div>

                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-6">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Danh mục</label>
                            <select asp-for="CategoryID" class="form-select" asp-items="Model.Categories">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Loại sản phẩm</label>
                            <select asp-for="ProductTypeID" class="form-select" asp-items="Model.ProductTypes"></select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Đơn vị tính</label>
                            <select asp-for="BaseUnitID" class="form-select" asp-items="Model.Units"></select>
                            <span asp-validation-for="BaseUnitID" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-semibold">Giá vốn</label>
                                <input asp-for="CostPrice" type="number" step="0.01" class="form-control" />
                            </div>

                            <div class="col-6 mb-3">
                                <label class="form-label fw-semibold">Giá bán</label>
                                <input asp-for="StandardPrice" type="number" step="0.01" class="form-control" />
                            </div>
                        </div>

                    </div>

                </div>

                <!-- FOOTER -->
                <div class="mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Lưu cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}