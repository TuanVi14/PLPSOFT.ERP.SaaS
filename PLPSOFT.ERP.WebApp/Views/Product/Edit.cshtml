@model PLPSOFT.ERP.WebApp.Models.ProductViewModel

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<!-- HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-pencil-square text-primary me-2"></i>
        Chỉnh sửa sản phẩm
        <small>@Model.ProductName</small>
    </h1>

    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<!-- CHỌN CÔNG TY -->
<div class="plp-card">
    <div class="plp-card-body">
        <form asp-action="Edit" method="get">
            <input type="hidden" name="id" value="@Model.ProductID" />

            <label class="plp-form-label">Công ty</label>
            <select disabled name="companyId"
                    class="form-select"
                    asp-items="Model.Companies"
                    onchange="this.form.submit()">
                <option value="">-- Chọn công ty --</option>
            </select>
        </form>
    </div>
</div>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="plp-alert plp-alert-danger"></div>

    <input type="hidden" asp-for="ProductID" />
    <input type="hidden" asp-for="CompanyID" />

    <!-- THÔNG TIN CƠ BẢN -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-info-circle"></i> Thông tin sản phẩm
            </h2>
        </div>

        <div class="plp-card-body">
            <div class="row g-3">

                <div class="col-md-6">
                    <label class="plp-form-label">Mã sản phẩm</label>
                    <input asp-for="ProductCode" class="form-control" readonly />
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Tên sản phẩm</label>
                    <input asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Danh mục</label>
                    <select asp-for="CategoryID" class="form-select" asp-items="Model.Categories">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Loại sản phẩm</label>
                    <select asp-for="ProductTypeID" class="form-select" asp-items="Model.ProductTypes"></select>
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Đơn vị tính</label>
                    <select asp-for="BaseUnitID" class="form-select" asp-items="Model.Units"></select>
                    <span asp-validation-for="BaseUnitID" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label class="plp-form-label">Giá vốn</label>
                    <input asp-for="CostPrice" type="number" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="plp-form-label">Giá bán</label>
                    <input asp-for="StandardPrice" type="number" class="form-control" />
                </div>

                <div class="col-md-6">
                    <div class="form-check mt-3">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label class="form-check-label">Hoạt động</label>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ĐỊNH DANH -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-upc-scan"></i> Định danh sản phẩm
            </h2>
        </div>

        <div class="plp-card-body">
            <div class="row g-3">

                <div class="col-md-6">
                    <label class="plp-form-label">SKU</label>
                    <input asp-for="Sku" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Barcode</label>
                    <input asp-for="Barcode" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Thương hiệu</label>
                    <input asp-for="Brand" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Xuất xứ</label>
                    <input asp-for="Origin" class="form-control" />
                </div>

            </div>
        </div>
    </div>

    <!-- THUẾ -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-percent"></i> Thuế
            </h2>
        </div>

        <div class="plp-card-body">
            <label class="plp-form-label">Thuế mặc định</label>
            <select asp-for="DefaultTaxRateID" asp-items="Model.TaxRates" class="form-select">
                <option value="">-- Chọn thuế --</option>
            </select>
        </div>
    </div>

    <!-- KHO -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-boxes"></i> Kho & Vận hành
            </h2>
        </div>

        <div class="plp-card-body">

            <div class="form-check mb-2">
                <input asp-for="TrackInventory" class="form-check-input" />
                <label class="form-check-label">Theo dõi tồn kho</label>
            </div>

            <div class="form-check mb-3">
                <input asp-for="AllowBackorder" class="form-check-input" />
                <label class="form-check-label">Cho phép bán khi hết hàng</label>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="plp-form-label">Tồn tối thiểu</label>
                    <input asp-for="MinStock" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Tồn tối đa</label>
                    <input asp-for="MaxStock" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Trọng lượng</label>
                    <input asp-for="Weight" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Thể tích</label>
                    <input asp-for="Volume" class="form-control" />
                </div>
            </div>

        </div>
    </div>

    <!-- KỸ THUẬT -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-gear"></i> Kỹ thuật & Bảo hành
            </h2>
        </div>

        <div class="plp-card-body">

            <div class="form-check mb-2">
                <input asp-for="IsSerialized" class="form-check-input" />
                <label class="form-check-label">Quản lý Serial</label>
            </div>

            <div class="form-check mb-2">
                <input asp-for="IsBatchManaged" class="form-check-input" />
                <label class="form-check-label">Quản lý theo lô</label>
            </div>

            <div class="form-check mb-3">
                <input asp-for="ExpireDateRequired" class="form-check-input" />
                <label class="form-check-label">Yêu cầu hạn sử dụng</label>
            </div>

            <div>
                <label class="plp-form-label">Bảo hành (tháng)</label>
                <input asp-for="WarrantyMonths" class="form-control" />
            </div>

        </div>
    </div>

    <!-- ACTION -->
    <div class="plp-form-actions">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>

        <button type="submit" class="btn btn-primary btn-lg">
            <i class="bi bi-check-lg"></i> Lưu
        </button>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}