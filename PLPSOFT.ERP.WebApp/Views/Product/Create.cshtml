@model PLPSOFT.ERP.WebApp.Models.ProductViewModel

@{
    ViewData["Title"] = "Thêm mới sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">@ViewData["Title"]</h1>

    <!-- Breadcrumb -->
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Sản phẩm</a></li>
        <li class="breadcrumb-item active">Thêm mới</li>
    </ol>

    <div class="card shadow-sm">
        <!-- HEADER -->
        <div class="card-header bg-light">
            <i class="fas fa-box-open me-1"></i>
            <span class="fw-bold">Thông tin sản phẩm</span>
        </div>

        <!-- BODY -->
        <div class="card-body">
            <form asp-action="Create" method="get">
                    <select asp-for="CompanyID"
                            class="form-select"
                            asp-items="Model.Companies"
                            onchange="this.form.submit()">
                        <option value="">-- Chọn công ty --</option>
                    </select>
            </form>
            
            <form asp-action="Create" method="post">
                <input type="hidden" asp-for="CompanyID" />
                <div class="row">

                    <!-- LEFT -->
                    <div class="col-md-6">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mã sản phẩm</label>
                            <input asp-for="ProductCode" class="form-control" placeholder="VD: SP-001" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tên sản phẩm</label>
                            <input asp-for="ProductName" class="form-control" />
                        </div>

                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-6">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Danh mục</label>
                            <select asp-for="CategoryID" class="form-select" asp-items="Model.Categories">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Loại sản phẩm</label>
                            <select asp-for="ProductTypeID" class="form-select" asp-items="Model.ProductTypes"></select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Đơn vị tính</label>
                            <select asp-for="BaseUnitID" class="form-select" asp-items="Model.Units">
                                <option value="">-- Chọn đơn vị tính --</option>
                            </select>
                            <span asp-validation-for="BaseUnitID" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-semibold">Giá vốn</label>
                                <input asp-for="CostPrice" type="number" class="form-control" />
                            </div>

                            <div class="col-6 mb-3">
                                <label class="form-label fw-semibold">Giá bán</label>
                                <input asp-for="StandardPrice" type="number" class="form-control" />
                            </div>
                        </div>

                    </div>
                </div>
                <hr />
                <h5 class="text-primary">Định danh sản phẩm</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">SKU</label>
                        <input asp-for="Sku" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Barcode</label>
                        <input asp-for="Barcode" class="form-control" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Thương hiệu</label>
                        <input asp-for="Brand" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Xuất xứ</label>
                        <input asp-for="Origin" class="form-control" />
                    </div>
                </div>

                <hr />
                <h5 class="text-primary">Thuế</h5>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Thuế mặc định</label>
                    <select asp-for="DefaultTaxRateID" asp-items="Model.TaxRates" class="form-select">
                        <option value="">-- Chọn thuế --</option>
                    </select>
                </div>

                <hr />
                <h5 class="text-primary">Kho & Vận hành</h5>

                <div class="form-check mb-2">
                    <input asp-for="TrackInventory" class="form-check-input" />
                    <label class="form-check-label fw-semibold">Theo dõi tồn kho</label>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="AllowBackorder" class="form-check-input" />
                    <label class="form-check-label fw-semibold">Cho phép bán khi hết hàng</label>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Tồn tối thiểu</label>
                        <input asp-for="MinStock" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Tồn tối đa</label>
                        <input asp-for="MaxStock" class="form-control" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Trọng lượng</label>
                        <input asp-for="Weight" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Thể tích</label>
                        <input asp-for="Volume" class="form-control" />
                    </div>
                </div>

                <hr />
                <h5 class="text-primary">Kỹ thuật & Bảo hành</h5>

                <div class="form-check mb-2">
                    <input asp-for="IsSerialized" class="form-check-input" />
                    <label class="form-check-label fw-semibold">Quản lý Serial</label>
                </div>

                <div class="form-check mb-2">
                    <input asp-for="IsBatchManaged" class="form-check-input" />
                    <label class="form-check-label fw-semibold">Quản lý theo lô</label>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="ExpireDateRequired" class="form-check-input" />
                    <label class="form-check-label fw-semibold">Yêu cầu hạn sử dụng</label>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Bảo hành (tháng)</label>
                    <input asp-for="WarrantyMonths" class="form-control" />
                </div>


                <!-- FOOTER -->
                <div class="mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Lưu sản phẩm
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>