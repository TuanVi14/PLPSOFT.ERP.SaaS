@model IEnumerable<PLPSOFT.ERP.WebApp.Models.ProductViewModel>

@{
    ViewData["Title"] = "Danh sách Sản phẩm";
}

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-box-seam text-primary me-2"></i>
        Sản phẩm
        <small>Quản lý kho hàng</small>
    </h1>

    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Thêm sản phẩm
    </a>
</div>

<!-- FILTER -->
<div class="plp-filter-bar">
    <form asp-action="Index" method="get">
        <div class="row g-2">
            <div class="col-md-8">
                <div class="plp-search-group">
                    <i class="bi bi-search plp-search-icon"></i>
                    <input type="text" name="searchString"
                           value="@ViewData["CurrentFilter"]"
                           class="form-control plp-search-input"
                           placeholder="Tìm mã hoặc tên..." />
                </div>
            </div>

            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-search"></i> Tìm
                </button>

                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                }
            </div>
        </div>
    </form>
</div>

<!-- TABLE -->
<div class="plp-card">
    <div class="plp-card-header">
        <h2 class="plp-card-title">
            <i class="bi bi-table"></i> Danh sách sản phẩm
        </h2>
    </div>

    <div class="plp-table-wrap">
        <table class="plp-table">
            <thead>
                <tr>
                    <th>Mã SP</th>
                    <th>Tên sản phẩm</th>
                    <th>Công ty</th>
                    <th>Danh mục</th>
                    <th class="col-num">Giá vốn</th>
                    <th class="col-num">Giá bán</th>
                    <th class="col-center">Trạng thái</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>
            <tbody>

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8">
                            <div class="plp-empty">
                                <i class="bi bi-inbox"></i>
                                <p>Không có dữ liệu</p>
                            </div>
                        </td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    <tr class="@(!item.IsActive ? "row-inactive" : "")">

                        <td>
                            <span class="plp-code">@item.ProductCode</span>
                        </td>

                        <td>@item.ProductName</td>

                        <td class="text-muted">
                            @item.Company?.ShortName
                        </td>

                        <td>
                            <span class="plp-badge plp-badge-info">
                                @item.Category?.CategoryName
                            </span>
                        </td>

                        <td class="col-num">
                            @item.CostPrice.ToString("N0")
                        </td>

                        <td class="col-num fw-semibold">
                            @item.StandardPrice.ToString("N0")
                        </td>

                        <td class="col-center">
                            @if (item.IsActive)
                            {
                                <span class="plp-badge plp-badge-success">
                                    <i class="bi bi-check-circle-fill"></i> Hoạt động
                                </span>
                            }
                            else
                            {
                                <span class="plp-badge plp-badge-muted">
                                    <i class="bi bi-slash-circle"></i> Ngừng
                                </span>
                            }
                        </td>

                        <td class="col-actions">
                            <div class="d-flex justify-content-center gap-1">

                                <a asp-action="Details" asp-route-id="@item.ProductID"
                                   class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i>
                                </a>

                                @if (item.IsActive)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.ProductID"
                                       class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <button class="btn btn-sm btn-outline-danger"
                                            onclick="confirmDelete(@item.ProductID)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-success"
                                            onclick="restoreProduct(@item.ProductID)">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                }

                            </div>
                        </td>

                    </tr>
                }

            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm("Ngừng kinh doanh sản phẩm này?")) {
                $.post('/Product/Delete/' + id, function (res) {
                    if (res.success) location.reload();
                    else alert(res.message);
                });
            }
        }

        function restoreProduct(id) {
            if (confirm("Kích hoạt lại sản phẩm?")) {
                $.post('/Product/Restore/' + id, function (res) {
                    if (res.success) location.reload();
                    else alert(res.message);
                });
            }
        }
    </script>
}