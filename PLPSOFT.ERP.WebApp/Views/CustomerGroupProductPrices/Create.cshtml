@model PLPSOFT.ERP.WebApp.Models.CustomerGroupProductPriceFormViewModel
@{
    ViewData["Title"] = "Thêm giá nhóm khách hàng";
}

<div class="plp-page">

    <!-- PAGE HEADER -->
    <div class="plp-page-header">
        <div>
            <h3 class="plp-page-title">
                <i class="bi bi-tags text-primary me-1"></i>
                Thêm giá nhóm khách hàng
            </h3>

            <div class="plp-text-muted">
                Tạo mới giá bán theo nhóm khách hàng
            </div>

            <div class="plp-breadcrumb">
                <a asp-action="Index">Giá nhóm</a>
                <span>/</span>
                <span>Thêm mới</span>
            </div>
        </div>
    </div>

    <!-- FORM CARD -->
    <div class="plp-card" style="max-width: 860px;">
        <div class="plp-card-body">
            <form asp-action="Create" method="post" class="plp-form">
                @Html.AntiForgeryToken()

                <partial name="_Form" model="@Model" />
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}