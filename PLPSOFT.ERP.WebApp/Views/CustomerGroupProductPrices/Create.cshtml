@model PLPSOFT.ERP.Domain.Entities.MasterData.CustomerGroupProductPrice

@{
    ViewData["Title"] = "Tạo Mới Giá";
}

<div class="card shadow">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label class="control-label fw-bold">Nhóm Khách Hàng</label>
                <select asp-for="CustomerGroupId" class="form-control" asp-items="ViewBag.CustomerGroupId">
                    <option value="">-- Chọn Nhóm --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label class="control-label fw-bold">Sản Phẩm</label>
                <select asp-for="ProductId" class="form-control" asp-items="ViewBag.ProductId">
                    <option value="">-- Chọn Sản Phẩm --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Price" class="control-label fw-bold">Giá Bán</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary">Lưu Dữ Liệu</button>
                <a asp-action="Index" class="btn btn-secondary">Quay Lại</a>
            </div>
        </form>
    </div>
</div>