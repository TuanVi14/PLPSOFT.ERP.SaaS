@model PLPSOFT.ERP.WebApp.Models.CustomerGroupProductPriceFormViewModel
@{
    ViewData["Title"] = "Sửa giá nhóm khách hàng";
}

<div class="plp-page">

    <!-- PAGE HEADER -->
    <div class="plp-page-header">
        <div>
            <h3 class="plp-page-title">
                <i class="bi bi-tags text-primary me-1"></i>
                Sửa giá nhóm khách hàng
            </h3>

            <div class="plp-text-muted">
                Chỉnh sửa bản ghi #@Model.GroupPriceID
            </div>

            <div class="plp-breadcrumb">
                <a asp-action="Index">Giá nhóm</a>
                <span>/</span>
                <span>Chỉnh sửa #@Model.GroupPriceID</span>
            </div>
        </div>
    </div>

    <!-- FORM CARD -->
    <div class="plp-card" style="max-width: 860px;">
        <div class="plp-card-body">
            <form asp-action="Edit"
                  asp-route-id="@Model.GroupPriceID"
                  method="post"
                  class="plp-form">
                @Html.AntiForgeryToken()
                <input asp-for="GroupPriceID" type="hidden" />

                <partial name="_Form" model="@Model" />
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}