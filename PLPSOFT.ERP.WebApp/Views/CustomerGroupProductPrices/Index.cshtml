@model PLPSOFT.ERP.WebApp.Models.CustomerGroupProductPriceListViewModel
@{
    ViewData["Title"] = "Giá bán theo nhóm khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-tags-fill text-primary me-2"></i>Giá bán theo nhóm khách hàng</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Thêm mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}


<div class="card mb-3 shadow-sm">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label form-label-sm mb-1">Nhóm khách hàng</label>
                <select name="Filter.CustomerGroupID" class="form-select form-select-sm">
                    <option value="">-- Tất cả --</option>
                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.CustomerGroupOptions)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label form-label-sm mb-1">Sản phẩm</label>
                <select name="Filter.ProductID" class="form-select form-select-sm">
                    <option value="">-- Tất cả --</option>
                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.ProductOptions)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label form-label-sm mb-1">Trạng thái</label>
                <select name="Filter.IsActive" class="form-select form-select-sm">
                    <option value="">-- Tất cả --</option>

                    @if (Model.Filter.IsActive == true)
                    {
                        <option value="true" selected>Đang hoạt động</option>
                    }
                    else
                    {
                        <option value="true">Đang hoạt động</option>
                    }

                    @if (Model.Filter.IsActive == false)
                    {
                        <option value="false" selected>Đã tắt</option>
                    }
                    else
                    {
                        <option value="false">Đã tắt</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label form-label-sm mb-1">Từ khóa</label>
                <input type="text" name="Filter.Keyword" value="@Model.Filter.Keyword"
                       class="form-control form-control-sm" placeholder="Mã / tên nhóm, sản phẩm..." />
            </div>
            <div class="col-12 col-md-1 d-flex gap-1">
                <button type="submit" class="btn btn-sm btn-outline-primary w-100">
                    <i class="bi bi-search"></i>Lọc
                </button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary w-100" title="Xóa lọc">
                    <i class="bi bi-x-lg"></i>Đặt lại
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Nhóm khách hàng</th>
                        <th>Sản phẩm</th>
                        <th class="text-end">Giá riêng</th>
                        <th class="text-end">Chiết khấu</th>
                        <th>Hiệu lực từ</th>
                        <th>Hiệu lực đến</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-4 d-block mb-1"></i>
                                Không có dữ liệu
                            </td>
                        </tr>
                    }
                    @{int stt = (Model.PageIndex - 1) * Model.PageSize + 1;}
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="ps-3 text-muted">@(stt++)</td>
                            <td>
                                <span class="badge bg-secondary me-1">@item.GroupCode</span>
                                @item.GroupName
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border me-1">@item.ProductCode</span>
                                @item.ProductName
                            </td>
                            <td class="text-end fw-semibold">
                                @(item.Price.HasValue ? item.Price.Value.ToString("N0") + " ₫" : "–")
                            </td>
                            <td class="text-end">
                                @(item.DiscountRate.HasValue ? item.DiscountRate.Value.ToString("0.##") + "%" : "–")
                            </td>
                            <td>@item.EffectiveFrom.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.EffectiveTo.HasValue)
                                {
                                    @item.EffectiveTo.Value.ToString("dd/MM/yyyy")
                                }
                                else
                                {
                                    @Html.Raw("<span class='text-muted fst-italic'>Không giới hạn</span>")
                                }
                            </td>
                            <td class="text-center">
                                @if (item.IsCurrentlyValid)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success">Đang áp dụng</span>
                                }
                                else if (!item.IsActive)
                                {
                                    <span class="badge bg-secondary">Tắt</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning">Chưa / Hết hạn</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@item.GroupPriceID"
                                       class="btn btn-outline-info" title="Xem">
                                        <i class="bi bi-eye"></i>Xem
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.GroupPriceID"
                                       class="btn btn-outline-warning" title="Sửa">
                                        <i class="bi bi-pencil"></i>Sửa
                                    </a>
                                    <button type="button"
                                            class="btn btn-outline-secondary btn-toggle-active"
                                            data-id="@item.GroupPriceID"
                                            data-active="@item.IsActive.ToString().ToLower()"
                                            title="@(item.IsActive ? "Tắt" : "Bật")">
                                        <i class="bi @(item.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off")"></i>@(item.IsActive ? "Tắt" : "Bật")
                                    </button>
                                    <a asp-action="Delete" asp-route-id="@item.GroupPriceID"
                                       class="btn btn-outline-danger" title="Xóa">
                                        <i class="bi bi-trash"></i>Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">
                Hiển thị @((Model.PageIndex - 1) * Model.PageSize + 1)–@(Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount))
                trong tổng số @Model.TotalCount bản ghi
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.PageIndex - 1)"
                           asp-route-Filter.CustomerGroupID="@Model.Filter.CustomerGroupID"
                           asp-route-Filter.ProductID="@Model.Filter.ProductID"
                           asp-route-Filter.IsActive="@Model.Filter.IsActive"
                           asp-route-Filter.Keyword="@Model.Filter.Keyword">‹</a>
                    </li>
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@p"
                               asp-route-Filter.CustomerGroupID="@Model.Filter.CustomerGroupID"
                               asp-route-Filter.ProductID="@Model.Filter.ProductID"
                               asp-route-Filter.IsActive="@Model.Filter.IsActive"
                               asp-route-Filter.Keyword="@Model.Filter.Keyword">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.PageIndex + 1)"
                           asp-route-Filter.CustomerGroupID="@Model.Filter.CustomerGroupID"
                           asp-route-Filter.ProductID="@Model.Filter.ProductID"
                           asp-route-Filter.IsActive="@Model.Filter.IsActive"
                           asp-route-Filter.Keyword="@Model.Filter.Keyword">›</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script>
    document.querySelectorAll('.btn-toggle-active').forEach(btn => {
        btn.addEventListener('click', async () => {
            const id = btn.dataset.id;
            const res = await fetch(`/CustomerGroupProductPrices/ToggleActive`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                },
                body: `id=${id}`
            });
            const data = await res.json();
            if (data.success) location.reload();
        });
    });
    </script>
}
