@model PLPSOFT.ERP.WebApp.Models.CustomerGroupProductPriceListViewModel
@{
    ViewData["Title"] = "Giá bán theo nhóm khách hàng";
}

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-tags text-primary me-2"></i>
        Giá bán theo nhóm khách hàng
        <small>Quản lý giá bán theo từng nhóm khách hàng</small>
    </h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Thêm mới
    </a>
</div>

<!-- ALERT -->
@if (TempData["Success"] != null)
{
    <div class="plp-alert plp-alert-success">
        <i class="bi bi-check-circle"></i>
        <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="plp-alert plp-alert-danger">
        <i class="bi bi-exclamation-triangle"></i>
        <div>@TempData["Error"]</div>
    </div>
}

<!-- FILTER BAR -->
<div class="plp-filter-bar">
    <form method="get">
        <div class="row g-2">

            <div class="col-md-3">
                <label class="plp-form-label">Nhóm khách hàng</label>
                <select name="Filter.CustomerGroupID" class="form-select">
                    <option value="">-- Tất cả --</option>
                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.CustomerGroupOptions)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="plp-form-label">Sản phẩm</label>
                <select name="Filter.ProductID" class="form-select">
                    <option value="">-- Tất cả --</option>
                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.ProductOptions)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="plp-form-label">Trạng thái</label>
                <select name="Filter.IsActive" class="form-select">
                    <option value="">-- Tất cả --</option>

                    @if (Model.Filter.IsActive == true)
                    {
                        <option value="true" selected>Đang hoạt động</option>
                    }
                    else
                    {
                        <option value="true">Đang hoạt động</option>
                    }

                    @if (Model.Filter.IsActive == false)
                    {
                        <option value="false" selected>Đã tắt</option>
                    }
                    else
                    {
                        <option value="false">Đã tắt</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="plp-form-label">Từ khóa</label>
                <div class="plp-search-group">
                    <i class="bi bi-search plp-search-icon"></i>
                    <input type="text" name="Filter.Keyword"
                           value="@Model.Filter.Keyword"
                           class="form-control plp-search-input"
                           placeholder="Mã / tên nhóm, sản phẩm..." />
                </div>
            </div>

            <div class="col-md-1 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i>
                </button>
                <a asp-action="Index" class="btn btn-secondary w-100">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>

        </div>
    </form>
</div>

<!-- TABLE CARD -->
<div class="plp-card">
    <div class="plp-card-header">
        <h2 class="plp-card-title">
            <i class="bi bi-table"></i> Danh sách giá
        </h2>
    </div>

    <div class="plp-table-wrap">
        <table class="plp-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nhóm khách hàng</th>
                    <th>Sản phẩm</th>
                    <th class="col-num">Giá riêng</th>
                    <th class="col-num">Chiết khấu</th>
                    <th>Hiệu lực từ</th>
                    <th>Hiệu lực đến</th>
                    <th class="col-center">Trạng thái</th>
                    <th class="col-actions">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="9">
                            <div class="plp-empty">
                                <i class="bi bi-inbox"></i>
                                <p>Không có dữ liệu</p>
                            </div>
                        </td>
                    </tr>
                }

                @{
                    int stt = (Model.PageIndex - 1) * Model.PageSize + 1;
                }

                @foreach (var item in Model.Items)
                {
                    <tr class="@(!item.IsActive ? "row-inactive" : "")">
                        <td>@(stt++)</td>

                        <td>
                            <span class="plp-code">@item.GroupCode</span>
                            @item.GroupName
                        </td>

                        <td>
                            <span class="plp-code">@item.ProductCode</span>
                            @item.ProductName
                        </td>

                        <td class="col-num fw-semibold">
                            @(item.Price.HasValue? item.Price.Value.ToString("N0") + " ₫" : "–")
                        </td>

                        <td class="col-num">
                            @(item.DiscountRate.HasValue? item.DiscountRate.Value.ToString("0.##") + "%" : "–")
                        </td>

                        <td>@item.EffectiveFrom.ToString("dd/MM/yyyy")</td>

                        <td>
                            @if (item.EffectiveTo.HasValue)
                            {
                                @item.EffectiveTo.Value.ToString("dd/MM/yyyy")
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Không giới hạn</span>
                            }
                        </td>

                        <td class="col-center">
                            @if (item.IsCurrentlyValid)
                            {
                                <span class="plp-badge plp-badge-success">
                                    <i class="bi bi-check-circle"></i> Đang áp dụng
                                </span>
                            }
                            else if (!item.IsActive)
                            {
                                <span class="plp-badge plp-badge-muted">
                                    <i class="bi bi-slash-circle"></i> Tắt
                                </span>
                            }
                            else
                            {
                                <span class="plp-badge plp-badge-warning">
                                    <i class="bi bi-exclamation-circle"></i> Chưa / Hết hạn
                                </span>
                            }
                        </td>

                        <td class="col-actions">
                            <div class="d-flex justify-content-center gap-1">
                                <a asp-action="Details" asp-route-id="@item.GroupPriceID"
                                   class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.GroupPriceID"
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary btn-toggle-active"
                                        data-id="@item.GroupPriceID"
                                        data-active="@item.IsActive.ToString().ToLower()">
                                    <i class="bi @(item.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off")"></i>
                                </button>

                                <a asp-action="Delete" asp-route-id="@item.GroupPriceID"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- PAGINATION -->
    @if (Model.TotalPages > 1)
    {
        <div class="plp-pagination-wrap">
            <div>
                Hiển thị @((Model.PageIndex - 1) * Model.PageSize + 1)
                –
                @(Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount))
                / @Model.TotalCount bản ghi
            </div>

            <ul class="pagination">
                <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(Model.PageIndex - 1)">‹</a>
                </li>

                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                    </li>
                }

                <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(Model.PageIndex + 1)">›</a>
                </li>
            </ul>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-toggle-active').forEach(btn => {
            btn.addEventListener('click', async () => {
                const id = btn.dataset.id;
                const res = await fetch(`/CustomerGroupProductPrices/ToggleActive`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                    },
                    body: `id=${id}`
                });
                const data = await res.json();
                if (data.success) location.reload();
            });
        });
    </script>
}