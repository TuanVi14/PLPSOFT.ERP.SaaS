@model PLPSOFT.ERP.WebApp.Models.CustomerGroupProductPriceRowViewModel
@{
    ViewData["Title"] = "Chi tiết giá nhóm";
}

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-tags text-primary me-2"></i>
        Chi tiết giá nhóm
        <small>Bản ghi #@Model.GroupPriceID</small>
    </h1>
</div>

<!-- BREADCRUMB -->
<div class="plp-breadcrumb-wrap mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-action="Index">Giá nhóm</a>
        </li>
        <li class="breadcrumb-item active">
            Chi tiết #@Model.GroupPriceID
        </li>
    </ol>
</div>

<!-- DETAIL CARD -->
<div class="plp-card" style="max-width: 700px;">
    <div class="plp-card-header">
        <h2 class="plp-card-title">
            <i class="bi bi-info-circle"></i> Thông tin chi tiết
        </h2>

        @if (Model.IsCurrentlyValid)
        {
            <span class="plp-badge plp-badge-success">
                <i class="bi bi-check-circle"></i> Đang áp dụng
            </span>
        }
    </div>

    <div class="plp-card-body">
        <dl class="plp-detail-grid">

            <dt>Nhóm khách hàng</dt>
            <dd>
                <span class="plp-code">@Model.GroupCode</span>
                @Model.GroupName
            </dd>

            <dt>Sản phẩm</dt>
            <dd>
                <span class="plp-code">@Model.ProductCode</span>
                @Model.ProductName
            </dd>

            <dt>Giá riêng</dt>
            <dd class="fw-semibold text-primary">
                @(Model.Price.HasValue? Model.Price.Value.ToString("N0") + " ₫" : "–")
            </dd>

            <dt>Chiết khấu</dt>
            <dd>
                @(Model.DiscountRate.HasValue? Model.DiscountRate.Value.ToString("0.##") + "%" : "–")
            </dd>

            <dt>Hiệu lực từ</dt>
            <dd>@Model.EffectiveFrom.ToString("dd/MM/yyyy")</dd>

            <dt>Hiệu lực đến</dt>
            <dd>
                @if (Model.EffectiveTo.HasValue)
                {
                    @Model.EffectiveTo.Value.ToString("dd/MM/yyyy")
                }
                else
                {
                    <span class="text-muted fst-italic">Không giới hạn</span>
                }
            </dd>

            <dt>Trạng thái</dt>
            <dd>
                @if (Model.IsActive)
                {
                    <span class="plp-badge plp-badge-success">
                        <i class="bi bi-check-circle"></i> Kích hoạt
                    </span>
                }
                else
                {
                    <span class="plp-badge plp-badge-muted">
                        <i class="bi bi-slash-circle"></i> Đã tắt
                    </span>
                }
            </dd>

        </dl>
    </div>
</div>

<!-- ACTIONS -->
<div class="plp-form-actions" style="max-width: 700px;">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.GroupPriceID"
           class="btn btn-outline-warning">
            <i class="bi bi-pencil"></i> Sửa
        </a>

        <a asp-action="Delete" asp-route-id="@Model.GroupPriceID"
           class="btn btn-outline-danger">
            <i class="bi bi-trash"></i> Xóa
        </a>
    </div>
</div>