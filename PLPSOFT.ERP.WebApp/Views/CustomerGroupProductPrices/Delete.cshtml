@model PLPSOFT.ERP.WebApp.Models.CustomerGroupProductPriceRowViewModel
@{
    ViewData["Title"] = "Xóa giá nhóm";
}

<div class="card shadow-sm border-danger" style="max-width: 600px;">
    <div class="card-header bg-danger text-white">
        <i class="bi bi-exclamation-triangle me-2"></i> Xác nhận xóa bản ghi #@Model.GroupPriceID
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            Bạn có chắc muốn <strong>xóa vĩnh viễn</strong> bản ghi giá này? Thao tác không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-5">Nhóm khách hàng</dt>
            <dd class="col-sm-7">@Model.GroupCode – @Model.GroupName</dd>

            <dt class="col-sm-5">Sản phẩm</dt>
            <dd class="col-sm-7">[@Model.ProductCode] @Model.ProductName</dd>

            <dt class="col-sm-5">Giá riêng / Chiết khấu</dt>
            <dd class="col-sm-7">
                @(Model.Price.HasValue? Model.Price.Value.ToString("N0") + " ₫" : "–")
                /
                @(Model.DiscountRate.HasValue? Model.DiscountRate.Value + "%" : "–")
            </dd>

            <dt class="col-sm-5">Khoảng thời gian</dt>
            <dd class="col-sm-7">
                @Model.EffectiveFrom.ToString("dd/MM/yyyy") →
                @(Model.EffectiveTo.HasValue? Model.EffectiveTo.Value.ToString("dd/MM/yyyy") : "∞")
            </dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete" asp-route-id="@Model.GroupPriceID" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i> Xóa
            </button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</div>
