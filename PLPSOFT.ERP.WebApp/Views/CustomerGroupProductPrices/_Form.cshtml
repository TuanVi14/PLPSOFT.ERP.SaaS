@model PLPSOFT.ERP.WebApp.Models.CustomerGroupProductPriceFormViewModel

<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

<div class="row g-3">
    <div class="col-12 col-md-6">
        <label asp-for="CustomerGroupID" class="form-label fw-semibold"></label>
        <select asp-for="CustomerGroupID"
                asp-items="@Model.CustomerGroupOptions"
                class="form-select">
            <option value="">-- Chọn nhóm khách hàng --</option>
        </select>
        <span asp-validation-for="CustomerGroupID" class="text-danger small"></span>
    </div>

    <div class="col-12 col-md-6">
        <label asp-for="ProductID" class="form-label fw-semibold"></label>
        <select asp-for="ProductID"
                asp-items="@Model.ProductOptions"
                class="form-select">
            <option value="">-- Chọn sản phẩm --</option>
        </select>
        <span asp-validation-for="ProductID" class="text-danger small"></span>
    </div>

    <div class="col-12 col-md-4">
        <label asp-for="Price" class="form-label fw-semibold"></label>
        <div class="input-group">
            <input asp-for="Price" type="number" min="0" step="1000"
                   class="form-control" placeholder="Nhập giá..." />
            <span class="input-group-text">₫</span>
        </div>
        <span asp-validation-for="Price" class="text-danger small"></span>
        <div class="form-text">Để trống nếu chỉ dùng chiết khấu.</div>
    </div>

    <div class="col-12 col-md-4">
        <label asp-for="DiscountRate" class="form-label fw-semibold"></label>
        <div class="input-group">
            <input asp-for="DiscountRate" type="number" min="0" max="100" step="0.01"
                   class="form-control" placeholder="0.00" />
            <span class="input-group-text">%</span>
        </div>
        <span asp-validation-for="DiscountRate" class="text-danger small"></span>
    </div>

    <div class="col-12 col-md-4 d-flex align-items-end pb-1">
        <div class="form-check form-switch">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
            <label asp-for="IsActive" class="form-check-label fw-semibold">Kích hoạt</label>
        </div>
    </div>

    <div class="col-12 col-md-6">
        <label asp-for="EffectiveFrom" class="form-label fw-semibold"></label>
        <input asp-for="EffectiveFrom" type="date" class="form-control" />
        <span asp-validation-for="EffectiveFrom" class="text-danger small"></span>
    </div>

    <div class="col-12 col-md-6">
        <label asp-for="EffectiveTo" class="form-label fw-semibold"></label>
        <input asp-for="EffectiveTo" type="date" class="form-control" />
        <span asp-validation-for="EffectiveTo" class="text-danger small"></span>
        <div class="form-text">Để trống = không giới hạn thời gian.</div>
    </div>
</div>
