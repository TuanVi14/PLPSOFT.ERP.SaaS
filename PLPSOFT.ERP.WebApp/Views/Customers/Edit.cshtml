@using PLPSOFT.ERP.Domain.Entities.MasterData
@model Customer

<div class="container mt-4">
    <h2 class="mb-4">Sửa khách hàng</h2>

    <form asp-action="Edit" method="post" class="card p-4 shadow-sm">
        <input type="hidden" asp-for="CustomerId" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Mã</label>
                <input asp-for="CustomerCode" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Tên</label>
                <input asp-for="CustomerName" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Nhóm</label>
                <select asp-for="CustomerGroupId" class="form-select" asp-items="@(new SelectList(ViewBag.CustomerGroups, "CustomerGroupID", "GroupName", Model.CustomerGroupId))">
                    <option value="">-- Chọn nhóm --</option>
                </select>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Phone</label>
                <input asp-for="Phone" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Giới hạn tín dụng</label>
                <input asp-for="CreditLimit" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Số ngày thanh toán</label>
                <input asp-for="PaymentTermDays" class="form-control" />
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>