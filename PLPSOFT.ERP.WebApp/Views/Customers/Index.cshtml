@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.Customer>
@{
    ViewData["Title"] = "Danh sách khách hàng";
}

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-people text-primary me-2"></i>
        Khách hàng
        <small>Quản lý danh sách khách hàng</small>
    </h1>

    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Thêm khách hàng
    </a>
</div>

<!-- ALERT -->
@if (TempData["Success"] != null)
{
    <div class="plp-alert plp-alert-success">
        <i class="bi bi-check-circle"></i>
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="plp-alert plp-alert-danger">
        <i class="bi bi-exclamation-triangle"></i>
        @TempData["Error"]
    </div>
}

<!-- FILTER -->
<div class="plp-filter-bar">
    <form asp-action="Index" method="get">
        <div class="row g-2 align-items-center">

            <div class="col-md-6">
                <div class="plp-search-group">
                    <i class="bi bi-search plp-search-icon"></i>
                    <input type="text"
                           name="searchString"
                           value="@ViewData["CurrentFilter"]"
                           class="form-control plp-search-input"
                           placeholder="Tìm theo tên, mã, SĐT, email, mã số thuế..." />
                </div>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Tìm
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>

            <div class="col-md-3 text-end text-muted small">
                Tổng: <strong>@Model.Count()</strong> khách hàng
            </div>

        </div>
    </form>
</div>

<!-- TABLE -->
<div class="plp-card">
    <div class="plp-card-header">
        <h2 class="plp-card-title">
            <i class="bi bi-table"></i> Danh sách khách hàng
        </h2>
    </div>

    <div class="plp-table-wrap">
        <table class="plp-table">
            <thead>
                <tr>
                    <th>Mã KH</th>
                    <th>Tên khách hàng</th>
                    <th>Công ty</th>
                    <th>Nhóm KH</th>
                    <th>Điện thoại</th>
                    <th class="col-center">Trạng thái</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7">
                            <div class="plp-empty">
                                <i class="bi bi-inbox"></i>
                                <p>Không có dữ liệu</p>
                            </div>
                        </td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    <tr class="@(!item.IsActive ? "row-inactive" : "")">

                        <!-- Mã -->
                        <td>
                            <span class="plp-code">@item.CustomerCode</span>
                        </td>

                        <!-- Tên -->
                        <td>
                            <a asp-action="Details"
                               asp-route-id="@item.CustomerId"
                               class="fw-medium text-dark text-decoration-none">
                                @item.CustomerName
                            </a>

                            @if (!string.IsNullOrEmpty(item.Email))
                            {
                                <div class="text-muted small">@item.Email</div>
                            }
                        </td>

                        <!-- Công ty -->
                        <td class="text-muted">@item.Company?.CompanyName</td>

                        <!-- Nhóm -->
                        <td class="text-muted">
                            @(item.CustomerGroup?.GroupName ?? "—")
                        </td>

                        <!-- Phone -->
                        <td class="text-muted">
                            @(item.Phone ?? "—")
                        </td>

                        <!-- Trạng thái -->
                        <td class="col-center">
                            @if (item.IsActive)
                            {
                                <span class="plp-badge plp-badge-success">
                                    <i class="bi bi-check-circle"></i> Hoạt động
                                </span>
                            }
                            else
                            {
                                <span class="plp-badge plp-badge-muted">
                                    <i class="bi bi-slash-circle"></i> Ngừng
                                </span>
                            }
                        </td>

                        <!-- ACTION -->
                        <td class="col-actions">
                            <div class="d-flex justify-content-center gap-1">

                                <a asp-action="Details"
                                   asp-route-id="@item.CustomerId"
                                   class="btn btn-sm btn-outline-secondary"
                                   title="Chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.CustomerId"
                                   class="btn btn-sm btn-outline-warning"
                                   title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a asp-controller="CustomerAddresses"
                                   asp-action="Index"
                                   asp-route-customerId="@item.CustomerId"
                                   class="btn btn-sm btn-outline-info"
                                   title="Địa chỉ">
                                    <i class="bi bi-geo-alt"></i>
                                </a>

                                @if (item.IsActive)
                                {
                                    <form asp-action="Delete"
                                          asp-route-id="@item.CustomerId"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa khách hàng này?');">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                                title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Restore"
                                          asp-route-id="@item.CustomerId"
                                          method="post"
                                          class="d-inline">
                                        @Html.AntiForgeryToken()
                                         
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                    </form>
                                }

                            </div>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>