@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.Customer>

@{
    ViewData["Title"] = "Danh sách khách hàng";
}

<h2>Danh sách khách hàng</h2>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Tìm theo mã/tên/số điện thoại" />
        <button class="btn btn-outline-secondary" type="submit">Tìm</button>
        <a asp-action="Create" class="btn btn-primary ms-2">Thêm khách hàng</a>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Mã</th>
            <th>Tên</th>
            <th>Nhóm</th>
            <th>Điện thoại</th>
            <th>Email</th>
            <th>Công ty</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var c in Model)
    {
        <tr>
            <td>@c.CustomerCode</td>
            <td>@c.CustomerName</td>
            <td>@(c.CustomerGroup?.GroupName ?? "-")</td>
            <td>@c.Phone</td>
            <td>@c.Email</td>
            <td>@c.Company?.CompanyName</td>
            <td>@(c.IsActive ? "Active" : "Inactive")</td>
            <td>
                <a asp-action="Details" asp-route-id="@c.CustomerId" class="btn btn-sm btn-outline-secondary">Chi tiết</a>
                <a asp-action="Edit" asp-route-id="@c.CustomerId" class="btn btn-sm btn-outline-primary">Sửa</a>
                <form asp-action="Delete" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@c.CustomerId" />
                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xác nhận ngừng hoạt động?');">Ngừng</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
