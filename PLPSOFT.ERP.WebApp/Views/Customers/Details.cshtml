@model PLPSOFT.ERP.Domain.Entities.MasterData.Customer
@{
    ViewData["Title"] = "Chi tiết khách hàng";
    string V(string? v) => string.IsNullOrEmpty(v) ? "—" : v;
}

<!-- HEADER -->
<div class="plp-page-header">
    <div>
        <h1 class="plp-page-title">
            <i class="bi bi-person text-primary me-2"></i>
            @Model.CustomerName
            <small>
                <span class="plp-code">@Model.CustomerCode</span>
            </small>
        </h1>

        @if (Model.IsActive)
        {
            <span class="plp-badge plp-badge-success">
                <i class="bi bi-check-circle"></i> Hoạt động
            </span>
        }
        else
        {
            <span class="plp-badge plp-badge-muted">
                <i class="bi bi-slash-circle"></i> Ngừng hoạt động
            </span>
        }
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.CustomerId"
           class="btn btn-primary">
            <i class="bi bi-pencil"></i> Chỉnh sửa
        </a>

        <button type="button"
                class="btn btn-danger"
                onclick="confirmDelete(@Model.CustomerId, '@Html.Raw(Model.CustomerName.Replace("'", "\\'"))')">
            <i class="bi bi-trash"></i> Xóa
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
    </div>
</div>

<div class="row g-4">

    <!-- ===== LEFT ===== -->
    <div class="col-lg-8">

        <!-- THÔNG TIN CƠ BẢN -->
        <div class="plp-card mb-4">
            <div class="plp-card-header">
                <h2 class="plp-card-title">
                    <i class="bi bi-person-vcard"></i> Thông tin cơ bản
                </h2>
            </div>

            <div class="plp-card-body">
                <div class="plp-detail-grid">

                    <div class="label">Công ty</div>
                    <div>@V(Model.Company?.CompanyName)</div>

                    <div class="label">Mã khách hàng</div>
                    <div><span class="plp-code">@V(Model.CustomerCode)</span></div>

                    <div class="label">Tên khách hàng</div>
                    <div class="fw-medium">@V(Model.CustomerName)</div>

                    <div class="label">Loại khách hàng</div>
                    <div>@V(Model.CustomerType?.ValueName)</div>

                    <div class="label">Nhóm khách hàng</div>
                    <div>@V(Model.CustomerGroup?.GroupName)</div>

                    <div class="label">Mã số thuế</div>
                    <div>@V(Model.TaxCode)</div>

                </div>
            </div>
        </div>

        <!-- LIÊN HỆ -->
        <div class="plp-card mb-4">
            <div class="plp-card-header">
                <h2 class="plp-card-title">
                    <i class="bi bi-telephone"></i> Thông tin liên hệ
                </h2>
            </div>

            <div class="plp-card-body">
                <div class="plp-detail-grid">

                    <div class="label">Điện thoại</div>
                    <div>@V(Model.Phone)</div>

                    <div class="label">Email</div>
                    <div>
                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <a href="mailto:@Model.Email">@Model.Email</a>
                        }
                        else { <span>—</span> }
                    </div>

                    <div class="label">Facebook</div>
                    <div>
                        @if (!string.IsNullOrEmpty(Model.Facebook))
                        {
                            <a href="@Model.Facebook" target="_blank">@Model.Facebook</a>
                        }
                        else { <span>—</span> }
                    </div>

                    <div class="label">Zalo</div>
                    <div>@V(Model.Zalo)</div>

                </div>
            </div>
        </div>

        <!-- CÁ NHÂN -->
        <div class="plp-card mb-4">
            <div class="plp-card-header">
                <h2 class="plp-card-title">
                    <i class="bi bi-person"></i> Thông tin cá nhân
                </h2>
            </div>

            <div class="plp-card-body">
                <div class="plp-detail-grid">

                    <div class="label">Giới tính</div>
                    <div>
                        @(Model.Gender switch {
                            "Male" => "Nam",
                            "Female" => "Nữ",
                            "Other" => "Khác",
                            _ => "—"
                        })
                    </div>

                    <div class="label">Ngày sinh</div>
                    <div>
                        @(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "—")
                    </div>

                </div>
            </div>
        </div>

        <!-- ĐỊA CHỈ -->
        <div class="plp-card mb-4">
            <div class="plp-card-header d-flex justify-content-between">
                <h2 class="plp-card-title">
                    <i class="bi bi-geo-alt"></i> Địa chỉ
                </h2>

                <a asp-controller="CustomerAddresses"
                   asp-action="Index"
                   asp-route-customerId="@Model.CustomerId"
                   class="btn btn-sm btn-outline-primary">
                    Quản lý
                </a>
            </div>

            <div class="plp-card-body">

                @if (Model.CustomerAddresses?.Any() == true)
                {
                    <div class="plp-list">
                        @foreach (var addr in Model.CustomerAddresses.OrderByDescending(a => a.IsDefault))
                        {
                            <div class="plp-list-item">

                                <div class="fw-semibold">
                                    @addr.ReceiverName

                                    @if (addr.IsDefault)
                                    {
                                        <span class="plp-badge plp-badge-primary">Mặc định</span>
                                    }
                                </div>

                                <div class="text-muted small">
                                    @addr.Address,
                                    @addr.Ward,
                                    @addr.District,
                                    @addr.Province
                                </div>

                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="plp-empty">
                        <i class="bi bi-geo-alt"></i>
                        <p>Chưa có địa chỉ</p>
                    </div>
                }

            </div>
        </div>

    </div>

    <!-- ===== RIGHT ===== -->
    <div class="col-lg-4">

        <!-- CÔNG NỢ -->
        <div class="plp-card mb-4">
            <div class="plp-card-header">
                <h2 class="plp-card-title">
                    <i class="bi bi-credit-card"></i> Tín dụng
                </h2>
            </div>

            <div class="plp-card-body">
                <div class="mb-3">
                    <div class="text-muted small">Hạn mức</div>
                    <div class="fw-semibold fs-5">
                        @Model.CreditLimit.ToString("N0") VNĐ
                    </div>
                </div>

                <div>
                    <div class="text-muted small">Công nợ</div>
                    <div class="fw-semibold fs-5">
                        @Model.PaymentTermDays ngày
                    </div>
                </div>
            </div>
        </div>

        <!-- ĐIỂM -->
        <div class="plp-card mb-4 text-center">
            <div class="plp-card-header">
                <h2 class="plp-card-title">
                    <i class="bi bi-star-fill text-warning"></i> Điểm tích lũy
                </h2>
            </div>

            <div class="plp-card-body">
                <div class="display-6 fw-bold text-warning">
                    @Model.LoyaltyPoint.ToString("N0")
                </div>
                <div class="text-muted">điểm</div>
            </div>
        </div>

        <!-- LỊCH SỬ -->
        <div class="plp-card mb-4">
            <div class="plp-card-header">
                <h2 class="plp-card-title">
                    <i class="bi bi-clock-history"></i> Lịch sử
                </h2>
            </div>

            <div class="plp-card-body">
                <div class="mb-2">
                    <div class="text-muted small">Ngày tạo</div>
                    <div>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>

                @if (Model.UpdatedAt.HasValue)
                {
                    <div>
                        <div class="text-muted small">Cập nhật</div>
                        <div>@Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                }
            </div>
        </div>

    </div>
</div>