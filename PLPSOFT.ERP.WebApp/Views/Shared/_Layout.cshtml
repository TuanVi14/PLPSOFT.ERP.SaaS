<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PLPSOFT ERP</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PLPSOFT.ERP.WebApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    PLPSOFT ERP
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarMain" aria-controls="navbarMain"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>

                        <!-- Khách hàng -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Khách hàng
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Customers" asp-action="Index">Danh sách khách hàng</a></li>
                                <li><a class="dropdown-item" asp-controller="CustomerGroups" asp-action="Index">Nhóm khách hàng</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="CustomerGroupProductPrices" asp-action="Index">Giá theo nhóm KH</a></li>
                            </ul>
                        </li>

                        <!-- Nhà cung cấp -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Nhà cung cấp
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="SupplierGroupsMVC" asp-action="Index">Nhóm nhà cung cấp</a></li>
                                <li><a class="dropdown-item" asp-controller="SuppliersMVC" asp-action="Index">Nhà cung cấp</a></li>
                            </ul>
                        </li>

                        <!-- Sản phẩm -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Sản phẩm
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index">Danh sách sản phẩm</a></li>
                                <li><a class="dropdown-item" asp-controller="ProductCategories" asp-action="Index">Danh mục sản phẩm</a></li>
                                <li><a class="dropdown-item" asp-controller="ProductUnits" asp-action="Index">Đơn vị tính</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="ProductUnitMapping" asp-action="Index">Quy đổi đơn vị</a></li>
                            </ul>
                        </li>

                        <!-- Định giá -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Định giá
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="TaxRates" asp-action="Index">Thuế suất</a></li>
                                <li><a class="dropdown-item" asp-controller="ProductPrices" asp-action="Index">Bảng giá sản phẩm</a></li>
                            </ul>
                        </li>

                    </ul>
                    <div class="d-flex">
                        <span class="text-white-50"><i class="fas fa-user-circle"></i> Admin</span>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - PLPSOFT ERP -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>