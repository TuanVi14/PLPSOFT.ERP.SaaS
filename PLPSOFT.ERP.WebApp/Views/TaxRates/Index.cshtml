@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.TaxRate>

@{
    ViewData["Title"] = "Danh sách thuế suất";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-percent me-2"></i>
            Danh sách thuế suất
        </h1>

        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item active">Thuế suất</li>
        </ol>
    </div>

    <!-- TOOLBAR -->
    <div class="card toolbar-card">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">

            <!-- SEARCH -->
            <form method="get" asp-action="Index" class="form-search d-flex">
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text"
                           name="keyword"
                           class="form-control"
                           placeholder="Tìm theo mã, tên, công ty..."
                           value="@Context.Request.Query["keyword"]" />
                </div>

                <button type="submit" class="btn btn-primary ms-2">
                    Tìm
                </button>
            </form>

            <!-- ADD -->
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>
                Thêm mới
            </a>

        </div>
    </div>

    <!-- TABLE -->
    <div class="card table-card mt-3">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle table-standard mb-0">

                    <thead>
                        <tr>
                            <th>Mã thuế</th>
                            <th>Tên thuế</th>
                            <th>Công ty</th>
                            <th class="text-end">Thuế suất (%)</th>
                            <th>Hiệu lực từ</th>
                            <th>Hiệu lực đến</th>
                            <th class="text-center">Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                    Không có dữ liệu
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr class="@(item.IsActive ? "" : "row-inactive")">

                                    <td class="fw-semibold">@item.TaxCode</td>

                                    <td>@item.TaxName</td>

                                    <td>@item.Company?.CompanyName</td>

                                    <td class="text-end fw-semibold text-success">
                                        @item.Rate.ToString("N2")
                                    </td>

                                    <td>@item.EffectiveFrom.ToString("dd/MM/yyyy")</td>

                                    <td>
                                        @(item.EffectiveTo.HasValue
                                                                        ? item.EffectiveTo.Value.ToString("dd/MM/yyyy")
                                                                        : "-")
                            </td>

                                    <!-- STATUS -->
                                    <td class="text-center">
                                @if (item.IsActive)
                                        {
                                            <span class="badge status-badge bg-success-subtle text-success">
                                                ● Đang hoạt động
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge status-badge bg-danger-subtle text-danger">
                                                ● Ngưng hoạt động
                                            </span>
                                        }
                                    </td>

                                    <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>

                                    <!-- ACTION -->
                                    <td class="text-center">
                                        <div class="action-buttons d-flex justify-content-center gap-1">

                                            @if (item.IsActive)
                                            {
                                                <a asp-action="Edit"
                                                   asp-route-id="@item.TaxRateId"
                                                   class="btn btn-sm btn-warning"
                                                   title="Sửa">
                                                    <i class="bi bi-pencil"></i>
                                                </a>

                                                <button type="button"
                                                        class="btn btn-sm btn-danger"
                                                        title="Xóa"
                                                        onclick="confirmDelete(@item.TaxRateId)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="btn btn-sm btn-success"
                                                        title="Khôi phục"
                                                        onclick="restoreTax(@item.TaxRateId)">
                                                    <i class="bi bi-arrow-clockwise"></i>
                                                </button>
                                            }

                                        </div>
                                    </td>

                                </tr>
                            }
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (!confirm("Bạn có chắc muốn xóa không?")) return;

            fetch('@Url.Action("Delete", "TaxRates")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ id: id })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert("Xóa thành công");
                    location.reload();
                } else {
                    alert("Xóa thất bại");
                }
            });
        }

        function restoreTax(id) {
            if (!confirm("Bạn có muốn khôi phục dữ liệu này không?")) return;

            fetch('@Url.Action("Restore", "TaxRates")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ id: id })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert("Khôi phục thành công");
                    location.reload();
                } else {
                    alert("Khôi phục thất bại");
                }
            });
        }
    </script>
}