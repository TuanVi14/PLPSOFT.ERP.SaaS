@model PLPSOFT.ERP.Domain.Entities.MasterData.TaxRate

@{
    ViewData["Title"] = "Cập nhật thuế suất";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-pencil-square me-2"></i>
            Cập nhật thuế suất
        </h1>

        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="Index">Thuế suất</a>
            </li>
            <li class="breadcrumb-item active">Cập nhật</li>
        </ol>
    </div>

    <!-- FORM -->
    <div class="card form-card">
        <div class="card-header">
            <i class="bi bi-info-circle me-1"></i>
            Thông tin thuế suất
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post" class="form-standard">

                <input type="hidden" asp-for="TaxRateId" />

                <div class="row">

                    <!-- Mã thuế -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="TaxCode" class="form-label">Mã thuế</label>
                            <input asp-for="TaxCode" class="form-control" />
                            <span asp-validation-for="TaxCode" class="form-error"></span>
                        </div>
                    </div>

                    <!-- Tên thuế -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="TaxName" class="form-label">Tên thuế</label>
                            <input asp-for="TaxName" class="form-control" />
                            <span asp-validation-for="TaxName" class="form-error"></span>
                        </div>
                    </div>

                    <!-- Thuế suất -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Rate" class="form-label">Thuế suất (%)</label>
                            <input asp-for="Rate"
                                   class="form-control"
                                   type="number"
                                   step="0.01" />
                        </div>
                    </div>

                    <!-- Công ty -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="CompanyId" class="form-label">Công ty</label>
                            <select asp-for="CompanyId"
                                    class="form-select"
                                    asp-items="@(new SelectList(ViewBag.Companies, "CompanyId", "CompanyName"))">
                                <option value="">-- Chọn công ty --</option>
                            </select>
                            <span asp-validation-for="CompanyId" class="form-error"></span>
                        </div>
                    </div>

                    <!-- Hiệu lực từ -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="EffectiveFrom" class="form-label">Hiệu lực từ</label>
                            <input asp-for="EffectiveFrom" class="form-control" type="date" />
                        </div>
                    </div>

                    <!-- Hiệu lực đến -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="EffectiveTo" class="form-label">Hiệu lực đến</label>
                            <input asp-for="EffectiveTo" class="form-control" type="date" />
                        </div>
                    </div>

                    <!-- Trạng thái -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Trạng thái</label>
                            <div>
                                <span class="badge bg-success">
                                    Đang hoạt động
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Ngày tạo -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Ngày tạo</label>
                            <input asp-for="CreatedAt"
                                   class="form-control"
                                   type="datetime-local"
                                   readonly />
                        </div>
                    </div>

                </div>

                <!-- ACTION -->
                <div class="form-actions">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i>
                        Quay lại
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i>
                        Cập nhật
                    </button>
                </div>

            </form>
        </div>
    </div>

</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}