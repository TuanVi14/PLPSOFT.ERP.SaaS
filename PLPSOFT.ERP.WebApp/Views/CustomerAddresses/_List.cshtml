@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.CustomerAddress>

<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Địa chỉ</strong>
        @if (Model != null && Model.Any()) {
            <a class="btn btn-sm btn-primary" href="@Url.Action("Create", "CustomerAddresses", new { customerId = Model.First().CustomerId })">Thêm địa chỉ</a>
        }
    </div>
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Người nhận</th>
                    <th>Số điện thoại</th>
                    <th>Địa chỉ</th>
                    <th>Phường/Quận/Tỉnh</th>
                    <th>Loại</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.ReceiverName</td>
                    <td>@a.Phone</td>
                    <td>@a.Address</td>
                    <td>@(a.Ward + ", " + a.District + ", " + a.Province)</td>
                    <td>
                        @(a.IsDefault ? "Mặc định" : "")
                        @(a.IsBillingAddress ? " | Billing" : "")
                        @(a.IsShippingAddress ? " | Shipping" : "")
                    </td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Details","CustomerAddresses", new { id = a.AddressId })">Xem</a>
                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Edit","CustomerAddresses", new { id = a.AddressId })">Sửa</a>
                        <a class="btn btn-sm btn-outline-danger" href="@Url.Action("Delete","CustomerAddresses", new { id = a.AddressId })">Xóa</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
