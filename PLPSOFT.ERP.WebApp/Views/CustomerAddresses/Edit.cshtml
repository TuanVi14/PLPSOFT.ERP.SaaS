@model PLPSOFT.ERP.Domain.Entities.MasterData.CustomerAddress

@{
    ViewData["Title"] = "Sửa địa chỉ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-pencil-square text-primary me-2"></i>
        Cập nhật địa chỉ
        <small>@ViewBag.CustomerName</small>
    </h1>
</div>

<!-- BREADCRUMB -->
<div class="plp-card">
    <div class="plp-card-body py-2">
        <nav class="plp-breadcrumb-wrap">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Customers" asp-action="Index">Khách hàng</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-action="Index" asp-route-customerId="@Model.CustomerId">
                        @ViewBag.CustomerName
                    </a>
                </li>
                <li class="breadcrumb-item active">
                    Sửa địa chỉ
                </li>
            </ol>
        </nav>
    </div>
</div>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="AddressId" />
    <input type="hidden" asp-for="CustomerId" />
    <input type="hidden" asp-for="CreatedAt" />

    <!-- SECTION: NGƯỜI NHẬN -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-person"></i> Người nhận
            </h2>
        </div>

        <div class="plp-card-body">
            <div class="row g-3">

                <div class="col-md-6">
                    <label class="plp-form-label">
                        Tên người nhận <span class="text-danger">*</span>
                    </label>
                    <input asp-for="ReceiverName" class="form-control" />
                    <span asp-validation-for="ReceiverName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="plp-form-label">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" />
                </div>

            </div>
        </div>
    </div>

    <!-- SECTION: ĐỊA CHỈ -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-map"></i> Địa chỉ
            </h2>
        </div>

        <div class="plp-card-body">
            <div class="row g-3">

                <div class="col-md-4">
                    <label class="plp-form-label">Tỉnh / Thành phố</label>
                    <input asp-for="Province" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label class="plp-form-label">Quận / Huyện</label>
                    <input asp-for="District" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label class="plp-form-label">Phường / Xã</label>
                    <input asp-for="Ward" class="form-control" />
                </div>

                <div class="col-12">
                    <label class="plp-form-label">
                        Địa chỉ chi tiết <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

            </div>
        </div>
    </div>

    <!-- SECTION: GHI CHÚ -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-sticky"></i> Ghi chú
            </h2>
        </div>

        <div class="plp-card-body">
            <textarea asp-for="Note" class="form-control" rows="2"></textarea>
        </div>
    </div>

    <!-- SECTION: TUỲ CHỌN -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-gear"></i> Tuỳ chọn
            </h2>
        </div>

        <div class="plp-card-body">
            <div class="d-flex flex-wrap gap-4">

                <div class="form-check">
                    <input asp-for="IsDefault" class="form-check-input" />
                    <label asp-for="IsDefault" class="form-check-label">
                        Địa chỉ mặc định
                    </label>
                </div>

                <div class="form-check">
                    <input asp-for="IsBillingAddress" class="form-check-input" />
                    <label asp-for="IsBillingAddress" class="form-check-label">
                        Địa chỉ thanh toán
                    </label>
                </div>

                <div class="form-check">
                    <input asp-for="IsShippingAddress" class="form-check-input" />
                    <label asp-for="IsShippingAddress" class="form-check-label">
                        Địa chỉ giao hàng
                    </label>
                </div>

            </div>
        </div>
    </div>

    <!-- ACTION -->
    <div class="plp-form-actions">
        <a asp-action="Index" asp-route-customerId="@Model.CustomerId"
           class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>

        <button type="submit" class="btn btn-primary btn-lg">
            <i class="bi bi-check-lg"></i> Cập nhật
        </button>
    </div>

</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}