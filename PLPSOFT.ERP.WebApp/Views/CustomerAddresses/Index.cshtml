@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.CustomerAddress>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Customers" asp-action="Index">Khách hàng</a></li>
            <li class="breadcrumb-item active">Địa chỉ của <strong>@ViewBag.CustomerName</strong></li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">Địa chỉ: @ViewBag.CustomerName</h4>
        <a asp-action="Create" asp-route-customerId="@ViewBag.CustomerId" class="btn btn-primary">
            + Thêm địa chỉ
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Khách hàng này chưa có địa chỉ nào.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-3">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm @(item.IsDefault ? "border-primary border-2" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="card-title fw-bold mb-0">@item.ReceiverName</h6>
                                <div class="d-flex gap-1 flex-wrap">
                                    @if (item.IsDefault)
                                    {
                                        <span class="badge bg-primary">Mặc định</span>
                                    }
                                    @if (item.IsBillingAddress)
                                    {
                                        <span class="badge bg-info text-dark">Thanh toán</span>
                                    }
                                    @if (item.IsShippingAddress)
                                    {
                                        <span class="badge bg-success">Giao hàng</span>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(item.Phone))
                            {
                                <p class="card-text text-muted small mb-1">
                                    <i class="bi bi-telephone"></i> @item.Phone
                                </p>
                            }

                            <p class="card-text mb-1">
                                @item.Address
                                @if (!string.IsNullOrEmpty(item.Ward))
                                {
                                    @(", " + item.Ward)
                                }
                                @if (!string.IsNullOrEmpty(item.District))
                                {
                                    @(", " + item.District)
                                }
                                @if (!string.IsNullOrEmpty(item.Province))
                                {
                                    @(", " + item.Province)
                                }
                            </p>

                            @if (!string.IsNullOrEmpty(item.Note))
                            {
                                <p class="card-text text-muted small">@item.Note</p>
                            }
                        </div>
                        <div class="card-footer bg-transparent d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.AddressId"
                               class="btn btn-sm btn-warning">Sửa</a>
                            <form asp-action="Delete" method="post" style="display:inline;"
                                  onsubmit="return confirm('Xóa địa chỉ này?')">
                                <input type="hidden" name="id" value="@item.AddressId" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-3">
        <a asp-controller="Customers" asp-action="Index" class="btn btn-secondary">
            ← Quay lại danh sách khách hàng
        </a>
    </div>
</div>


