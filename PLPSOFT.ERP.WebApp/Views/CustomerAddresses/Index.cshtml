@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.CustomerAddress>

@{
    ViewData["Title"] = "Địa chỉ khách hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-geo-alt text-primary me-2"></i>
        Địa chỉ khách hàng
        <small>@ViewBag.CustomerName</small>
    </h1>

    <a asp-action="Create" asp-route-customerId="@ViewBag.CustomerId"
       class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Thêm địa chỉ
    </a>
</div>

<!-- BREADCRUMB -->
<div class="plp-card">
    <div class="plp-card-body py-2">
        <nav class="plp-breadcrumb-wrap">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Customers" asp-action="Index">Khách hàng</a>
                </li>
                <li class="breadcrumb-item active">
                    @ViewBag.CustomerName
                </li>
            </ol>
        </nav>
    </div>
</div>

@if (!Model.Any())
{
    <div class="plp-card">
        <div class="plp-empty">
            <i class="bi bi-geo-alt"></i>
            <p>Khách hàng này chưa có địa chỉ nào</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">

        @foreach (var item in Model)
        {
            <div class="col-md-6">

                <div class="plp-card @(item.IsDefault ? "border border-primary" : "")">

                    <div class="plp-card-body">

                        <!-- HEADER -->
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <strong>@item.ReceiverName</strong>

                            <div class="d-flex gap-1 flex-wrap">

                                @if (item.IsDefault)
                                {
                                    <span class="plp-badge plp-badge-primary">
                                        Mặc định
                                    </span>
                                }

                                @if (item.IsBillingAddress)
                                {
                                    <span class="plp-badge plp-badge-info">
                                        Thanh toán
                                    </span>
                                }

                                @if (item.IsShippingAddress)
                                {
                                    <span class="plp-badge plp-badge-success">
                                        Giao hàng
                                    </span>
                                }

                            </div>
                        </div>

                        <!-- PHONE -->
                        @if (!string.IsNullOrEmpty(item.Phone))
                        {
                            <div class="text-muted small mb-1">
                                <i class="bi bi-telephone"></i> @item.Phone
                            </div>
                        }

                        <!-- ADDRESS -->
                        <div class="mb-1">
                            @item.Address
                            @if (!string.IsNullOrEmpty(item.Ward))
                            {
                                @(", " + item.Ward)
                            }
                            @if (!string.IsNullOrEmpty(item.District))
                            {
                                @(", " + item.District)
                            }
                            @if (!string.IsNullOrEmpty(item.Province))
                            {
                                @(", " + item.Province)
                            }
                        </div>

                        <!-- NOTE -->
                        @if (!string.IsNullOrEmpty(item.Note))
                        {
                            <div class="text-muted small">
                                @item.Note
                            </div>
                        }

                    </div>

                    <!-- ACTION -->
                    <div class="plp-card-header d-flex justify-content-end gap-2">

                        <a asp-action="Edit" asp-route-id="@item.AddressId"
                           class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <form asp-action="Delete" method="post"
                              onsubmit="return confirm('Xóa địa chỉ này?')">
                            <input type="hidden" name="id" value="@item.AddressId" />
                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>

                    </div>

                </div>

            </div>
        }

    </div>
}

<!-- BACK -->
<div class="plp-form-actions">
    <a asp-controller="Customers" asp-action="Index"
       class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>