@model PLPSOFT.ERP.Domain.Entities.MasterData.ProductPrice

@{
    ViewData["Title"] = "Tạo bảng giá sản phẩm";
}

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-currency-dollar text-primary me-2"></i>
        Tạo bảng giá sản phẩm
        <small>Khai báo giá bán cho sản phẩm</small>
    </h1>
</div>

<form asp-action="Create" method="post">

    <!-- VALIDATION -->
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <!-- FORM CARD -->
    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-info-circle"></i>
                Thông tin bảng giá
            </h2>
        </div>

        <div class="plp-card-body">
            <div class="row g-3">

                <!-- Công ty -->
                <div class="col-md-6">
                    <label class="plp-form-label">Công ty</label>
                    <select asp-for="CompanyId"
                            class="form-select"
                            onchange="window.location.href='?companyId=' + this.value">
                        <option value="0">-- Chọn công ty --</option>
                        @foreach (var c in ViewBag.Companies)
                        {
                            <option value="@c.CompanyId"
                                    selected="@(c.CompanyId == Model.CompanyId ? "selected" : null)">
                                @c.CompanyName
                            </option>
                        }
                    </select>
                    <span asp-validation-for="CompanyId" class="text-danger small"></span>
                </div>

                <!-- Chi nhánh -->
                <div class="col-md-6">
                    <label class="plp-form-label">Chi nhánh</label>
                    <select asp-for="BranchId" class="form-select">
                        <option value="">-- Chọn chi nhánh --</option>
                        @foreach (var b in ViewBag.Branches)
                        {
                            <option value="@b.BranchId">
                                @b.BranchName
                            </option>
                        }
                    </select>
                    <span asp-validation-for="BranchId" class="text-danger small"></span>
                </div>

                <!-- Sản phẩm -->
                <div class="col-md-6">
                    <label class="plp-form-label">Sản phẩm</label>
                    <select asp-for="ProductId" class="form-select">
                        <option value="">-- Chọn sản phẩm --</option>
                        @foreach (var p in ViewBag.Products)
                        {
                            <option value="@p.ProductId">
                                @p.ProductName
                            </option>
                        }
                    </select>
                    <span asp-validation-for="ProductId" class="text-danger small"></span>
                </div>

                <!-- Giá -->
                <div class="col-md-6">
                    <label asp-for="Price" class="plp-form-label">Giá</label>
                    <input asp-for="Price"
                           id="priceInput"
                           class="form-control"
                           placeholder="Nhập giá" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <!-- Hiệu lực từ -->
                <div class="col-md-6">
                    <label asp-for="EffectiveFrom" class="plp-form-label">Hiệu lực từ</label>
                    <input asp-for="EffectiveFrom"
                           type="date"
                           class="form-control" />
                    <span asp-validation-for="EffectiveFrom" class="text-danger small"></span>
                </div>

                <!-- Hiệu lực đến -->
                <div class="col-md-6">
                    <label asp-for="EffectiveTo" class="plp-form-label">Hiệu lực đến</label>
                    <input asp-for="EffectiveTo"
                           type="date"
                           class="form-control" />
                    <span asp-validation-for="EffectiveTo" class="text-danger small"></span>
                </div>

            </div>
        </div>
    </div>

    <!-- FORM ACTIONS -->
    <div class="plp-form-actions">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <button type="submit" class="btn btn-primary btn-lg">
            <i class="bi bi-check-lg"></i> Lưu
        </button>
    </div>

</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        const priceInput = document.getElementById("priceInput");

        function formatVND(value) {
            if (!value) return "";
            value = value.replace(/\D/g, "");
            return value.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        }

        priceInput.addEventListener("input", function (e) {
            e.target.value = formatVND(e.target.value);
        });

        document.querySelector("form").addEventListener("submit", function () {
            priceInput.value = priceInput.value.replace(/\./g, "");
        });
    </script>
}