@model PLPSOFT.ERP.Domain.Entities.MasterData.ProductPrice

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">Tạo bảng giá sản phẩm</h4>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="row">

                    <!-- ✅ Company -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Công ty</label>
                        <select asp-for="CompanyId" class="form-select"
                                onchange="window.location.href='?companyId=' + this.value">
                            <option value="0">-- Chọn công ty --</option>
                            @foreach (var c in ViewBag.Companies)
                            {
                                <option value="@c.CompanyId"
                                        selected="@(c.CompanyId == Model.CompanyId ? "selected" : null)">
                                    @c.CompanyName
                                </option>
                            }
                        </select>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <!-- ✅ Branch -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Chi nhánh</label>
                        <select asp-for="BranchId" class="form-select">
                            <option value="">-- Chọn chi nhánh --</option>
                            @foreach (var b in ViewBag.Branches)
                            {
                                <option value="@b.BranchId">
                                    @b.BranchName
                                </option>
                            }
                        </select>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    

                    <!-- ✅ Product -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Sản phẩm</label>
                        <select asp-for="ProductId" class="form-select">
                            <option value="">-- Chọn sản phẩm --</option>
                            @foreach (var p in ViewBag.Products)
                            {
                                <option value="@p.ProductId">
                                    @p.ProductName
                                </option>
                            }
                        </select>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <!-- ✅ Price -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label">Giá</label>
                        <input asp-for="Price"
                               id="priceInput"
                               class="form-control"
                               placeholder="Nhập giá" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <!-- ✅ Date -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="EffectiveFrom" class="form-label">Hiệu lực từ</label>
                        <input asp-for="EffectiveFrom" class="form-control" type="date" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="EffectiveTo" class="form-label">Hiệu lực đến</label>
                        <input asp-for="EffectiveTo" class="form-control" type="date" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                </div>

                <div class="d-flex justify-content-end">
                    <a asp-action="Index" class="btn btn-secondary me-2">Quay lại</a>
                    <button type="submit" class="btn btn-success">Lưu</button>
                </div>

            </form>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        const priceInput = document.getElementById("priceInput");

        function formatVND(value) {
            if (!value) return "";

            // bỏ ký tự không phải số
            value = value.replace(/\D/g, "");

            // format dạng 50.000
            return value.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        }

        // khi nhập
        priceInput.addEventListener("input", function (e) {
            e.target.value = formatVND(e.target.value);
        });

        // trước khi submit → bỏ dấu .
        document.querySelector("form").addEventListener("submit", function () {
            priceInput.value = priceInput.value.replace(/\./g, "");
        });
    </script>
}