@model PLPSOFT.ERP.Domain.Entities.MasterData.ProductPrice

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Cập nhật bảng giá sản phẩm</h4>
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="PriceId" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="ProductId" class="form-label">Mã sản phẩm</label>
                        <input asp-for="ProductId" class="form-control" placeholder="Nhập ProductId" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="BranchId" class="form-label">Mã chi nhánh</label>
                        <input asp-for="BranchId" class="form-control" placeholder="Nhập BranchId" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CompanyId" class="form-label">Mã công ty</label>
                        <input asp-for="CompanyId" class="form-control" placeholder="Nhập CompanyId" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label">Giá</label>
                        <input asp-for="Price"
                               id="priceInput"
                               class="form-control"
                               placeholder="Nhập giá " />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="EffectiveFrom" class="form-label">Hiệu lực từ</label>
                        <input asp-for="EffectiveFrom" class="form-control" type="date" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="EffectiveTo" class="form-label">Hiệu lực đến</label>
                        <input asp-for="EffectiveTo" class="form-control" type="date" />
                    </div>

                </div>

                <div class="d-flex justify-content-end">
                    <a asp-action="Index" class="btn btn-secondary me-2">Quay lại</a>
                    <button type="submit" class="btn btn-success">Cập nhật</button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        const priceInput = document.getElementById("priceInput");

        function formatNumber(value) {
            if (!value) return "";
            return value.replace(/\D/g, "")
                        .replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }

        priceInput.addEventListener("input", function (e) {
            e.target.value = formatNumber(e.target.value);
        });

        document.querySelector("form").addEventListener("submit", function () {
            priceInput.value = priceInput.value.replace(/,/g, "");
        });
    </script>
}