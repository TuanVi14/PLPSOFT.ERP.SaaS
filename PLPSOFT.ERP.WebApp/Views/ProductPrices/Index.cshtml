@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.ProductPrice>

@{
    ViewData["Title"] = "Danh sách bảng giá sản phẩm";
    var now = DateTime.Now;
}

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <div>
        <h1 class="plp-page-title">
            <i class="bi bi-currency-dollar text-primary me-2"></i>
            Bảng giá sản phẩm
            <small>Quản lý giá bán theo thời gian</small>
        </h1>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Thêm mới
    </a>
</div>

<!-- FILTER BAR -->
<div class="plp-filter-bar">
    <form asp-action="Index" method="get">
        <div class="row g-2">
            <div class="col-md-9">
                <div class="plp-search-group">
                    <i class="bi bi-search plp-search-icon"></i>
                    <input type="text"
                           name="keyword"
                           class="form-control plp-search-input"
                           placeholder="Tìm theo sản phẩm, chi nhánh, công ty..."
                           value="@Context.Request.Query["keyword"]" />
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-search"></i> Tìm
                </button>
            </div>
        </div>
    </form>
</div>

<!-- TABLE CARD -->
<div class="plp-card">
    <div class="plp-card-header">
        <h2 class="plp-card-title">
            <i class="bi bi-table"></i>
            Danh sách bảng giá
        </h2>
    </div>

    <div class="plp-table-wrap">
        <table class="plp-table">
            <thead>
                <tr>
                    <th>Sản phẩm</th>
                    <th>Chi nhánh</th>
                    <th>Công ty</th>
                    <th class="col-num">Giá</th>
                    <th>Hiệu lực từ</th>
                    <th>Hiệu lực đến</th>
                    <th class="col-center">Trạng thái</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8">
                            <div class="plp-empty">
                                <i class="bi bi-inbox"></i>
                                <p>Không có dữ liệu</p>
                            </div>
                        </td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    var isExpired = item.EffectiveTo.HasValue && item.EffectiveTo.Value <= now;

                    <tr class="@(isExpired ? "row-inactive" : "")">
                        <td>@item.Product?.ProductName</td>
                        <td>@item.Branch?.BranchName</td>
                        <td class="text-muted">@item.Company?.CompanyName</td>

                        <td class="col-num fw-mono text-success">
                            @item.Price.ToString("N0")
                        </td>

                        <td>@item.EffectiveFrom.ToString("dd/MM/yyyy")</td>
                        <td>
                            @(item.EffectiveTo.HasValue
                                                    ? item.EffectiveTo.Value.ToString("dd/MM/yyyy")
                                                    : "-")
                    </td>

                        <td class="col-center">
                        @if (isExpired)
                            {
                                <span class="plp-badge plp-badge-danger">
                                    <i class="bi bi-x-circle-fill"></i> Hết hạn
                                </span>
                            }
                            else
                            {
                                <span class="plp-badge plp-badge-success">
                                    <i class="bi bi-check-circle-fill"></i> Đang hoạt động
                                </span>
                            }
                        </td>

                        <td class="col-actions">
                            <div class="d-flex justify-content-center gap-1">
                                @if (isExpired)
                                {
                                    @* <button type="button"
                                            class="btn btn-sm btn-outline-success"
                                            title="Khôi phục"
                                            onclick="restorePrice(@item.PriceId)">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button> *@
                                }
                                else
                                {
                                    <a asp-action="Edit"
                                       asp-route-id="@item.PriceId"
                                       class="btn btn-sm btn-outline-warning"
                                       title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            title="Ngừng sử dụng"
                                            onclick="deletePrice(@item.PriceId)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function deletePrice(id) {
            if (!confirm("Bạn có chắc muốn xóa không?")) return;

            fetch('/ProductPrices/Delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: id })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) location.reload();
                else alert("Xóa thất bại");
            });
        }

        function restorePrice(id) {
            if (!confirm("Bạn có muốn khôi phục không?")) return;

            fetch('/ProductPrices/Restore', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: id })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) location.reload();
                else alert("Khôi phục thất bại");
            });
        }
    </script>
}