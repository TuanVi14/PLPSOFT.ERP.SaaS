@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.ProductPrice>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold">Danh sách bảng giá sản phẩm</h3>
        <a asp-action="Create" class="btn btn-primary">
            + Thêm mới
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-dark text-center">
                        <tr>
                            <th>Mã sản phẩm</th>
                            <th>Mã chi nhánh</th>
                            <th>Mã công ty</th>
                            <th>Giá</th>
                            <th>Hiệu lực từ</th>
                            <th>Hiệu lực đến</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ProductId</td>
                                <td>@item.BranchId</td>
                                <td>@item.CompanyId</td>

                                <td class="text-end fw-semibold text-success">
                                    @item.Price.ToString("N0")
                                </td>

                                <td>
                                    @item.EffectiveFrom.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    <span class="@(item.EffectiveTo.HasValue ? "" : "text-muted")">
                                        @(item.EffectiveTo.HasValue
                                         ? item.EffectiveTo.Value.ToString("dd/MM/yyyy")
                                       : "Không giới hạn")
                                </span>
                            </td>

                                <td class="text-center">
                                    <a asp-action="Edit"
                                       asp-route-id="@item.PriceId"
                                       class="btn btn-sm btn-warning">
                                        Sửa
                                    </a>
                                </td>
                            </tr>
                                                }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}