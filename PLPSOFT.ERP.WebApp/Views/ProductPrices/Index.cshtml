@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.ProductPrice>

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold">Danh sách bảng giá sản phẩm</h3>
        <a asp-action="Create" class="btn btn-primary">
            + Thêm mới
        </a>
    </div>

    <!-- Search -->
    <div class="mb-3">
        <div class="input-group">
            <span class="input-group-text">
                <i class="bi bi-search"></i>
            </span>
            <input type="text" id="searchInput" class="form-control"
                   placeholder="Tìm theo mã sản phẩm, chi nhánh, công ty..." />
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle" id="priceTable">
                    <thead class="table-dark text-center">
                        <tr>
                            <th>Mã sản phẩm</th>
                            <th>Mã chi nhánh</th>
                            <th>Mã công ty</th>
                            <th>Giá</th>
                            <th>Hiệu lực từ</th>
                            <th>Hiệu lực đến</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ProductId</td>
                                <td>@item.BranchId</td>
                                <td>@item.CompanyId</td>

                                <td class="text-end fw-semibold text-success">
                                    @item.Price.ToString("N0")
                                </td>

                                <td>
                                    @item.EffectiveFrom.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    <span class="@(item.EffectiveTo.HasValue ? "" : "text-muted")">
                                        @(item.EffectiveTo.HasValue
                                                                            ? item.EffectiveTo.Value.ToString("dd/MM/yyyy")
                                                                            : "Không giới hạn")
                                </span>
                            </td>

                                <td class="text-center">
                                    <a asp-action="Edit"
                                       asp-route-id="@item.PriceId"
                                       class="btn btn-sm btn-warning">
                                        Sửa
                                    </a>
                                </td>
                            </tr>
                                                }
                    </tbody>

                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        const searchInput = document.getElementById("searchInput");
        const rows = document.querySelectorAll("#priceTable tbody tr");

        let debounceTimer;

        searchInput.addEventListener("input", function () {
            clearTimeout(debounceTimer);

            debounceTimer = setTimeout(() => {
                const filter = searchInput.value.toLowerCase().replace(/,/g, "");

                rows.forEach(row => {
                    const cells = row.querySelectorAll("td");

                    let rowText = "";

                    // Gom toàn bộ text trong row + bỏ dấu phẩy (quan trọng cho giá)
                    cells.forEach(cell => {
                        rowText += cell.innerText.replace(/,/g, "") + " ";
                    });

                    rowText = rowText.toLowerCase();

                    if (rowText.includes(filter)) {
                        row.style.display = "";
                        highlightText(row, filter);
                    } else {
                        row.style.display = "none";
                        removeHighlight(row);
                    }
                });

            }, 300);
        });

        // Highlight
        function highlightText(row, keyword) {
            removeHighlight(row);

            if (!keyword) return;

            const cells = row.querySelectorAll("td");

            cells.forEach(cell => {
                const regex = new RegExp(`(${keyword})`, "gi");
                cell.innerHTML = cell.innerHTML.replace(regex, "<mark>$1</mark>");
            });
        }

        // Remove highlight
        function removeHighlight(row) {
            const marks = row.querySelectorAll("mark");
            marks.forEach(mark => {
                mark.replaceWith(mark.textContent);
            });
        }
    </script>
}