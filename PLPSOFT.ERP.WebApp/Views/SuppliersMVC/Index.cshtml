@model List<PLPSOFT.ERP.Domain.Entities.MasterData.Supplier>

@{
    ViewData["Title"] = "Danh sách nhà cung cấp";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="plp-page-header">
        <div>
            <h1 class="page-title">
                <i class="bi bi-people me-2"></i>
                Danh sách nhà cung cấp
            </h1>

            <div class="page-subtitle">
                Quản lý thông tin nhà cung cấp
            </div>
        </div>

        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i>
                Thêm mới
            </a>
        </div>
    </div>

    <!-- FILTER -->
    <div class="card form-card mb-3">
        <div class="card-body">
            <form method="get" class="form-standard">
                <div class="row g-3 align-items-center">

                    <div class="col-md-8">
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-search"></i>
                            </span>

                            <input type="text"
                                   name="search"
                                   value="@ViewBag.Search"
                                   class="form-control"
                                   placeholder="Tìm mã hoặc tên..." />
                        </div>
                    </div>

                    <div class="col-md-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search me-1"></i>
                            Tìm
                        </button>

                        @if (!string.IsNullOrEmpty(ViewBag.Search))
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-clockwise"></i>
                            </a>
                        }
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- TABLE -->
    <div class="card table-card">

        <div class="card-header">
            <i class="bi bi-table me-1"></i>
            Danh sách
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th style="width:120px;">Mã</th>
                            <th>Tên NCC</th>
                            <th>Loại NCC</th>
                            <th>Nhóm NCC</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th class="text-end" style="width:160px;">Giới hạn tín dụng</th>
                            <th class="text-center" style="width:120px;">Thanh toán</th>
                            <th class="text-center" style="width:150px;">Trạng thái</th>
                            <th class="text-center" style="width:160px;">Hành động</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="10" class="text-center text-muted py-4">
                                    Không có dữ liệu
                                </td>
                            </tr>
                        }

                        @foreach (var item in Model)
                        {
                            <tr class="@(item.IsDeleted ? "row-disabled" : "")">

                                <!-- CODE -->
                                <td class="text-nowrap fw-semibold text-primary">
                                    @item.SupplierCode
                                </td>

                                <!-- NAME -->
                                <td class="fw-medium">
                                    @item.SupplierName
                                </td>

                                <!-- TYPE -->
                                <td>
                                    @item.SupplierType?.ValueName
                                </td>

                                <!-- GROUP -->
                                <td>
                                    @item.SupplierGroup?.GroupName
                                </td>

                                <!-- PHONE -->
                                <td class="text-nowrap">
                                    @item.Phone
                                </td>

                                <!-- EMAIL -->
                                <td>
                                    @item.Email
                                </td>

                                <!-- CREDIT -->
                                <td class="text-end">
                                    @String.Format("{0:N0}", item.CreditLimit)
                                </td>

                                <!-- PAYMENT -->
                                <td class="text-center">
                                    @item.PaymentTermDays
                                </td>

                                <!-- STATUS -->
                                <td class="text-center">
                                    @if (item.IsDeleted)
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-trash me-1"></i>
                                            Đã xóa
                                        </span>
                                    }
                                    else if (item.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>
                                            Hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="bi bi-slash-circle me-1"></i>
                                            Ngừng
                                        </span>
                                    }
                                </td>

                                <!-- ACTION -->
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">

                                        <!-- EDIT -->
                                        <a asp-action="Edit"
                                           asp-route-id="@item.SupplierId"
                                           class="btn btn-sm btn-warning"
                                           title="Sửa">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        @if (!item.IsDeleted)
                                        {
                                            <!-- DELETE -->
                                            <a asp-action="Delete"
                                               asp-route-id="@item.SupplierId"
                                               class="btn btn-sm btn-danger"
                                               title="Xóa"
                                               onclick="return confirm('Bạn có chắc muốn xóa?')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <!-- RESTORE -->
                                            <a asp-action="Restore"
                                               asp-route-id="@item.SupplierId"
                                               class="btn btn-sm btn-success"
                                               title="Khôi phục">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </a>
                                        }

                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
    </div>

</div>

<style>
    .row-disabled {
        opacity: 0.5;
    }
</style>