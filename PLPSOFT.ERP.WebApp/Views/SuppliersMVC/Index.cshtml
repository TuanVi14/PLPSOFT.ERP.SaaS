@using PLPSOFT.ERP.Domain.Entities.MasterData
@model List<Supplier>

<div class="container mt-4">
    <h2 class="mb-4">Danh sách nhà cung cấp</h2>

    <div class="d-flex justify-content-between mb-3">

        <!-- Search -->
        <form method="get" class="d-flex" style="width: 300px;">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control me-2"
                   placeholder="🔍 Tìm mã hoặc tên..." />
            <button type="submit" class="btn btn-dark">Tìm</button>
        </form>

        <!-- Add -->
        <a class="btn btn-primary" href="/SuppliersMVC/Create">Thêm mới</a>
    </div>

    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Mã</th>
                <th>Tên</th>
                <th>Nhóm</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Tín dụng</th>
                <th>Thanh toán (ngày)</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.SupplierCode</td>
                    <td>@item.SupplierName</td>
                    <td>@item.SupplierGroup?.GroupName</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>@item.CreditLimit</td>
                    <td>@item.PaymentTermDays</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td>
                        <a class="btn btn-sm btn-warning" href="/SuppliersMVC/Edit/@item.SupplierID">Sửa</a>
                        <a class="btn btn-sm btn-danger" href="/SuppliersMVC/Delete/@item.SupplierID">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>