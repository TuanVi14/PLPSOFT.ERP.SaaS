@model PLPSOFT.ERP.Domain.Entities.MasterData.Supplier

@{
    ViewData["Title"] = "Sửa nhà cung cấp";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">

    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-pencil-square me-2"></i>
            Sửa nhà cung cấp
        </h1>

        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Nhà cung cấp</a></li>
            <li class="breadcrumb-item active">Sửa</li>
        </ol>
    </div>

    <div class="card form-card">
        <div class="card-header">
            <i class="bi bi-info-circle me-1"></i>
            Thông tin nhà cung cấp
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post" class="form-standard">

                <input type="hidden" asp-for="SupplierId" />

                <!-- SECTION: Thông tin chính -->
                <div class="form-section">
                    <div class="form-section-title">Thông tin chính</div>

                    <div class="row">
                        <div class="col-md-6">
                            <label class="form-label">Mã</label>
                            <input asp-for="SupplierCode" class="form-control" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label required">Tên</label>
                            <input asp-for="SupplierName" class="form-control" />
                            <span asp-validation-for="SupplierName" class="form-error"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Mã số thuế</label>
                            <input asp-for="TaxCode" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Nhóm</label>
                            <select asp-for="SupplierGroupId" class="form-select">
                                @foreach (var item in ViewBag.SupplierGroups)
                                {
                                    <option value="@item.SupplierGroupId">@item.GroupName</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <!-- SECTION: Liên hệ -->
                <div class="form-section">
                    <div class="form-section-title">Thông tin liên hệ</div>

                    <div class="row">
                        <div class="col-md-6">
                            <label class="form-label">Phone</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input asp-for="Phone" class="form-control" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECTION: Thanh toán -->
                <div class="form-section">
                    <div class="form-section-title">Thanh toán</div>

                    <div class="row">
                        <div class="col-md-6">
                            <label class="form-label">Giới hạn tín dụng</label>
                            <div class="input-group">
                                <input asp-for="CreditLimit" class="form-control" />
                                <span class="input-group-text">VNĐ</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Số ngày thanh toán</label>
                            <div class="input-group">
                                <input asp-for="PaymentTermDays" class="form-control" />
                                <span class="input-group-text">ngày</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Cập nhật
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>