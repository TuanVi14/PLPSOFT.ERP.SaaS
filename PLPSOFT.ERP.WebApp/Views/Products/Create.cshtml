@model PLPSOFT.ERP.WebApp.Models.ProductViewModel

@{
    ViewData["Title"] = "Thêm mới sản phẩm";
}

<div class="container mt-4">
    <h4>@ViewData["Title"]</h4>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div class="form-group mb-3">
                    <label class="control-label">Mã sản phẩm</label>
                    <input asp-for="ProductCode" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label class="control-label">Tên sản phẩm</label>
                    <input asp-for="ProductName" class="form-control" />
                </div>
                

                <div class="form-group mb-3">
                    <label class="control-label">Danh mục</label>
                    <select asp-for="CategoryID" class="form-control" asp-items="ViewBag.CategoryID">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label">Đơn vị tính</label>
                    <select asp-for="BaseUnitID" class="form-control" asp-items="ViewBag.BaseUnitID">
                        <option value="">-- Chọn đơn vị --</option>
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label">Giá chuẩn</label>
                    <input asp-for="StandardPrice" type="number" class="form-control" />
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-success">Lưu lại</button>
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}