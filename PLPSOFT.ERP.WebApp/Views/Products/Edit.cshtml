@model ProductViewModel
@{
    ViewData["Title"] = "Chỉnh sửa Sản phẩm";
}

<div class="container mt-4">
    <div class="card shadow border-warning">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">Chỉnh sửa Sản phẩm</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="ProductID" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Mã sản phẩm</label>
                        <input asp-for="ProductCode" class="form-control" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên sản phẩm</label>
                        <input asp-for="ProductName" class="form-control" required />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Danh mục</label>
                        <select asp-for="CategoryID" class="form-select" asp-items="ViewBag.CategoryID"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Đơn vị tính</label>
                        <select asp-for="BaseUnitID" class="form-select" asp-items="ViewBag.BaseUnitID"></select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Giá chuẩn</label>
                    <input asp-for="StandardPrice" type="number" class="form-control" />
                </div>

                <div class="mt-4 text-end">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-primary px-4">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>