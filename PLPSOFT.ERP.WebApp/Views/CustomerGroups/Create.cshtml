@model PLPSOFT.ERP.WebApp.Models.CustomerGroupViewModel

@{
    ViewData["Title"] = "Thêm nhóm khách hàng";
}

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <h1 class="plp-page-title">
        <i class="bi bi-diagram-3 text-primary me-2"></i>
        Thêm nhóm khách hàng
        <small>Tạo mới nhóm khách hàng</small>
    </h1>
</div>

<!-- FORM -->
<form asp-action="Create" method="post" style="max-width: 720px;">
    @Html.AntiForgeryToken()

    <!-- VALIDATION -->
    <div asp-validation-summary="ModelOnly" class="plp-alert plp-alert-danger"></div>

    <div class="plp-card">
        <div class="plp-card-header">
            <h2 class="plp-card-title">
                <i class="bi bi-pencil-square"></i> Thông tin nhóm khách hàng
            </h2>
        </div>

        <div class="plp-card-body">
            <div class="row g-3">

                <!-- Công ty -->
                <div class="col-md-6">
                    <label class="plp-form-label">Công ty</label>
                    <select asp-for="CompanyID"
                            class="form-select"
                            asp-items="ViewBag.Companies">
                        <option value="">-- Chọn công ty --</option>
                    </select>
                    <span asp-validation-for="CompanyID" class="text-danger small"></span>
                </div>

                <!-- Mã nhóm -->
                <div class="col-md-6">
                    <label asp-for="GroupCode" class="plp-form-label"></label>
                    <input asp-for="GroupCode" class="form-control" />
                    <span asp-validation-for="GroupCode" class="text-danger small"></span>
                </div>

                <!-- Tên nhóm -->
                <div class="col-md-6">
                    <label asp-for="GroupName" class="plp-form-label"></label>
                    <input asp-for="GroupName" class="form-control" />
                    <span asp-validation-for="GroupName" class="text-danger small"></span>
                </div>

                <!-- Mô tả -->
                <div class="col-md-12">
                    <label asp-for="Description" class="plp-form-label"></label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                </div>

                <!-- Trạng thái -->
                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ACTIONS -->
    <div class="plp-form-actions" style="max-width: 720px;">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Hủy
        </a>

        <button type="submit" class="btn btn-primary btn-lg">
            <i class="bi bi-check-lg"></i> Lưu
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}