@model PLPSOFT.ERP.Domain.Entities.MasterData.CustomerGroup

@{
    ViewData["Title"] = "Thêm nhóm khách hàng";
}

<h2>Thêm nhóm khách hàng</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">Công ty</label>
        <select asp-for="CompanyId" class="form-select" asp-items="ViewBag.Companies"></select>
    </div>
    <div class="mb-3">
        <label asp-for="GroupCode" class="form-label"></label>
        <input asp-for="GroupCode" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="GroupName" class="form-label"></label>
        <input asp-for="GroupName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <button class="btn btn-primary" type="submit">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
