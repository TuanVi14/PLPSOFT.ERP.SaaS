@model PLPSOFT.ERP.WebApp.Models.ProductUnitMappingRowViewModel
@{
    ViewData["Title"] = "Xóa đơn vị tính";
}

<div class="card shadow-sm border-danger" style="max-width: 560px;">
    <div class="card-header bg-danger text-white">
        <i class="bi bi-exclamation-triangle me-2"></i> Xác nhận xóa đơn vị tính
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            Bạn có chắc muốn <strong>xóa vĩnh viễn</strong> đơn vị tính này không?
        </div>
        <dl class="row">
            <dt class="col-sm-5">Sản phẩm</dt>
            <dd class="col-sm-7">[@ViewBag.ProductCode] @ViewBag.ProductName</dd>

            <dt class="col-sm-5">Đơn vị tính</dt>
            <dd class="col-sm-7">@Model.UnitCode – @Model.UnitName</dd>

            <dt class="col-sm-5">Tỷ lệ quy đổi</dt>
            <dd class="col-sm-7">@Model.ConversionRate.ToString("G")</dd>

            <dt class="col-sm-5">Mặc định</dt>
            <dd class="col-sm-7">
                @if (Model.IsDefault)
                {
                    <span class="badge bg-success">Có</span>
                }
                else
                {

                    <span class="text-muted">Không</span>
                }
            </dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="productId" value="@Model.ProductID" />
            <input type="hidden" name="unitId" value="@Model.UnitID" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i> Xóa
            </button>
        </form>
        <a asp-action="Index" asp-route-productId="@Model.ProductID"
           class="btn btn-outline-secondary">Hủy</a>
    </div>
</div>
