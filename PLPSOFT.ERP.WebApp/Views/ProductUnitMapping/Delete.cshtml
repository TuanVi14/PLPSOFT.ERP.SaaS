@model PLPSOFT.ERP.WebApp.Models.ProductUnitMappingRowViewModel
@{
    ViewData["Title"] = "Xóa đơn vị tính";
}

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="page-header">
        <div>
            <h1 class="page-title text-danger">
                <i class="bi bi-exclamation-triangle me-2"></i>
                Xác nhận xóa đơn vị tính
            </h1>

            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a asp-action="Index" asp-route-productId="@Model.ProductID">
                        Đơn vị tính
                    </a>
                </li>
                <li class="breadcrumb-item active">Xóa</li>
            </ol>
        </div>
    </div>

    <!-- CARD -->
    <div class="card border-danger shadow-sm" style="max-width: 560px;">

        <div class="card-header bg-danger text-white">
            <i class="bi bi-trash me-1"></i>
            Xóa đơn vị tính
        </div>

        <div class="card-body">

            <!-- WARNING -->
            <div class="alert alert-warning">
                Bạn có chắc muốn <strong>xóa vĩnh viễn</strong> đơn vị tính này không?
            </div>

            <!-- INFO -->
            <dl class="row mb-0">

                <dt class="col-sm-5">Sản phẩm</dt>
                <dd class="col-sm-7">
                    [@ViewBag.ProductCode] @ViewBag.ProductName
                </dd>

                <dt class="col-sm-5">Đơn vị tính</dt>
                <dd class="col-sm-7">
                    @Model.UnitCode – @Model.UnitName
                </dd>

                <dt class="col-sm-5">Tỷ lệ quy đổi</dt>
                <dd class="col-sm-7">
                    @Model.ConversionRate.ToString("G")
                </dd>

                <dt class="col-sm-5">Mặc định</dt>
                <dd class="col-sm-7">
                    @if (Model.IsDefault)
                    {
                        <span class="badge bg-success">Có</span>
                    }
                    else
                    {
                        <span class="text-muted">Không</span>
                    }
                </dd>

            </dl>

        </div>

        <!-- ACTION -->
        <div class="card-footer d-flex justify-content-between">

            <a asp-action="Index"
               asp-route-productId="@Model.ProductID"
               class="btn btn-secondary">
                Hủy
            </a>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.ProductID" />
                <input type="hidden" name="unitId" value="@Model.UnitID" />

                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>
                    Xóa
                </button>
            </form>

        </div>
    </div>

</div>