@model PLPSOFT.ERP.WebApp.Models.ProductUnitMappingListViewModel
@{
    ViewData["Title"] = "Quy đổi đơn vị tính sản phẩm";
    var productId = (long?)ViewBag.ProductId;
    var keyword = (string?)ViewBag.Keyword;
    var pageIndex = (int)ViewBag.PageIndex;
    var totalPages = (int)ViewBag.TotalPages;
    var totalCount = (int)ViewBag.TotalCount;
    var pageSize = (int)ViewBag.PageSize;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0">
            <i class="bi bi-arrow-left-right text-primary me-2"></i>
            Quy đổi đơn vị tính
            @if (!string.IsNullOrEmpty(Model.ProductName))
            {
                <small class="text-muted fs-6">— [@Model.ProductCode] @Model.ProductName</small>
            }
        </h4>
        @if (!string.IsNullOrEmpty(Model.BaseUnitName))
        {
            <small class="text-muted">Đơn vị cơ sở: <strong>@Model.BaseUnitName</strong></small>
        }
    </div>
    <a asp-action="Create" asp-route-productId="@productId" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Thêm đơn vị
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-3 shadow-sm">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label form-label-sm mb-1">Sản phẩm</label>
                <select name="productId" class="form-select form-select-sm">
                    <option value="">-- Tất cả sản phẩm --</option>
                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.ProductOptions)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-5">
                <label class="form-label form-label-sm mb-1">Từ khóa</label>
                <input type="text" name="keyword" value="@keyword"
                       class="form-control form-control-sm"
                       placeholder="Mã sản phẩm, tên đơn vị..." />
            </div>
            <div class="col-12 col-md-3 d-flex gap-1">
                <button type="submit" class="btn btn-sm btn-outline-primary flex-fill">
                    <i class="bi bi-search me-1"></i> Lọc
                </button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary" title="Xóa lọc">
                    <i class="bi bi-x-lg"></i>Đặt lại
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Sản phẩm</th>
                        <th>Đơn vị tính</th>
                        <th class="text-end">Tỷ lệ quy đổi</th>
                        <th class="text-center">Mặc định</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Mappings.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-4 d-block mb-1"></i>
                                Không có dữ liệu
                            </td>
                        </tr>
                    }
                    @foreach (var row in Model.Mappings)
                    {
                        <tr>
                            <td class="ps-3">
                                @if (string.IsNullOrEmpty(Model.ProductCode))
                                {
                                    <a asp-action="Index" asp-route-productId="@row.ProductID"
                                       class="text-decoration-none">
                                        <span class="badge bg-light text-dark border me-1">P-@row.ProductID</span>
                                        @row.ProductName
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-secondary me-1">@row.UnitCode</span>
                                @row.UnitName
                            </td>
                            <td class="text-end fw-semibold">
                                1 × @row.ConversionRate.ToString("G")
                                <small class="text-muted">(so với đơn vị cơ sở)</small>
                            </td>
                            <td class="text-center">
                                @if (row.IsDefault)
                                {
                                    <span class="badge bg-success"><i class="bi bi-star-fill me-1"></i>Mặc định</span>
                                }
                                else
                                {
                                    <button class="btn btn-link btn-sm p-0 text-muted btn-set-default"
                                            data-product-id="@row.ProductID"
                                            data-unit-id="@row.UnitID"
                                            title="Đặt làm mặc định">
                                        <i class="bi bi-star"></i>
                                    </button>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit"
                                       asp-route-productId="@row.ProductID"
                                       asp-route-unitId="@row.UnitID"
                                       class="btn btn-outline-warning" title="Sửa">
                                        <i class="bi bi-pencil"></i>Sửa
                                    </a>
                                    @if (!row.IsDefault)
                                    {
                                        <a asp-action="Delete"
                                           asp-route-productId="@row.ProductID"
                                           asp-route-unitId="@row.UnitID"
                                           class="btn btn-outline-danger" title="Xóa">
                                            <i class="bi bi-trash"></i>Xóa
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @((pageIndex - 1) * pageSize + 1)–@(Math.Min(pageIndex * pageSize, totalCount)) / @totalCount
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(pageIndex == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-productId="@productId" asp-route-keyword="@keyword"
                           asp-route-page="@(pageIndex - 1)">‹</a>
                    </li>
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        <li class="page-item @(p == pageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-productId="@productId" asp-route-keyword="@keyword"
                               asp-route-page="@p">@p</a>
                        </li>
                    }
                    <li class="page-item @(pageIndex == totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-productId="@productId" asp-route-keyword="@keyword"
                           asp-route-page="@(pageIndex + 1)">›</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-set-default').forEach(btn => {
            btn.addEventListener('click', async () => {
                const productId = btn.dataset.productId;
                const unitId    = btn.dataset.unitId;
                const token     = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                const res = await fetch(
                    `/ProductUnitMappings/SetDefault?productId=${productId}&unitId=${unitId}`,
                    { method: 'POST', headers: { 'RequestVerificationToken': token } }
                );
                const data = await res.json();
                if (data.success) location.reload();
            });
        });
    </script>
}
