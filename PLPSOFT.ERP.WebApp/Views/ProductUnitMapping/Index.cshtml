@model PLPSOFT.ERP.WebApp.Models.ProductUnitMappingListViewModel

@{
    ViewData["Title"] = "Quy đổi đơn vị tính sản phẩm";
    var productId = (long?)ViewBag.ProductId;
    var keyword = (string?)ViewBag.Keyword;
    var pageIndex = (int)ViewBag.PageIndex;
    var totalPages = (int)ViewBag.TotalPages;
    var totalCount = (int)ViewBag.TotalCount;
    var pageSize = (int)ViewBag.PageSize;
}

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <div>
        <h1 class="plp-page-title">
            <i class="bi bi-rulers text-primary me-2"></i>
            Quy đổi đơn vị tính
            @if (!string.IsNullOrEmpty(Model.ProductName))
            {
                <small>[@Model.ProductCode] @Model.ProductName</small>
            }
        </h1>

        @if (!string.IsNullOrEmpty(Model.BaseUnitName))
        {
            <div class="text-muted mt-1">
                Đơn vị cơ sở: <strong>@Model.BaseUnitName</strong>
            </div>
        }
    </div>

    <a asp-action="Create"
       asp-route-productId="@productId"
       class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Thêm đơn vị
    </a>
</div>

<!-- ALERT -->
@if (TempData["Success"] != null)
{
    <div class="plp-alert plp-alert-success">
        <i class="bi bi-check-circle"></i>
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="plp-alert plp-alert-danger">
        <i class="bi bi-exclamation-triangle"></i>
        @TempData["Error"]
    </div>
}

<!-- FILTER BAR -->
<div class="plp-filter-bar">
    <form method="get" asp-action="Index">
        <div class="row g-2">
            <div class="col-md-4">
                <label class="plp-form-label">Sản phẩm</label>
                <select name="productId" class="form-select">
                    <option value="">-- Tất cả sản phẩm --</option>
                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.ProductOptions)
                    {
                        <option value="@item.Value" selected="@item.Selected">
                            @item.Text
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-5">
                <label class="plp-form-label">Từ khóa</label>
                <div class="plp-search-group">
                    <i class="bi bi-search plp-search-icon"></i>
                    <input type="text"
                           name="keyword"
                           value="@keyword"
                           class="form-control plp-search-input"
                           placeholder="Mã sản phẩm, tên đơn vị..." />
                </div>
            </div>

            <div class="col-md-3 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-funnel"></i> Lọc
                </button>
                <a asp-action="Index" class="btn btn-secondary flex-fill">
                    Đặt lại
                </a>
            </div>
        </div>
    </form>
</div>

<!-- TABLE CARD -->
<div class="plp-card">
    <div class="plp-card-header">
        <h2 class="plp-card-title">
            <i class="bi bi-table"></i>
            Danh sách quy đổi
        </h2>
    </div>

    <div class="plp-table-wrap">
        <table class="plp-table">
            <thead>
                <tr>
                    <th>Sản phẩm</th>
                    <th>Đơn vị tính</th>
                    <th class="col-num">Tỷ lệ quy đổi</th>
                    <th class="col-center">Mặc định</th>
                    <th class="col-actions">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Mappings.Any())
                {
                    <tr>
                        <td colspan="5">
                            <div class="plp-empty">
                                <i class="bi bi-inbox"></i>
                                <p>Không có dữ liệu</p>
                            </div>
                        </td>
                    </tr>
                }

                @foreach (var row in Model.Mappings)
                {
                    <tr>
                        <td>
                            @if (string.IsNullOrEmpty(Model.ProductCode))
                            {
                                <a asp-action="Index"
                                   asp-route-productId="@row.ProductID"
                                   class="text-primary text-decoration-none">
                                    [P-@row.ProductID] @row.ProductName
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>

                        <td>
                            <span class="plp-code">@row.UnitCode</span>
                            @row.UnitName
                        </td>

                        <td class="col-num">
                            1 × @row.ConversionRate.ToString("G")
                            <span class="text-muted">(so với đơn vị cơ sở)</span>
                        </td>

                        <td class="col-center">
                            @if (row.IsDefault)
                            {
                                <span class="plp-badge plp-badge-success">
                                    <i class="bi bi-check-circle-fill"></i> Mặc định
                                </span>
                            }
                            else
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary btn-set-default"
                                        title="Đặt mặc định"
                                        data-product-id="@row.ProductID"
                                        data-unit-id="@row.UnitID">
                                    <i class="bi bi-star"></i>
                                </button>
                            }
                        </td>

                        <td class="col-actions">
                            <div class="d-flex justify-content-center gap-1">
                                <a asp-action="Edit"
                                   asp-route-productId="@row.ProductID"
                                   asp-route-unitId="@row.UnitID"
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                @if (!row.IsDefault)
                                {
                                    <a asp-action="Delete"
                                       asp-route-productId="@row.ProductID"
                                       asp-route-unitId="@row.UnitID"
                                       class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- PAGINATION -->
    @if (totalPages > 1)
    {
        <div class="plp-pagination-wrap">
            <div>
                @((pageIndex - 1) * pageSize + 1)–
                @(Math.Min(pageIndex * pageSize, totalCount))
                / @totalCount
            </div>

            <ul class="pagination">
                <li class="page-item @(pageIndex == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-productId="@productId"
                       asp-route-keyword="@keyword"
                       asp-route-page="@(pageIndex - 1)">‹</a>
                </li>

                @for (int p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == pageIndex ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-productId="@productId"
                           asp-route-keyword="@keyword"
                           asp-route-page="@p">@p</a>
                    </li>
                }

                <li class="page-item @(pageIndex == totalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-productId="@productId"
                       asp-route-keyword="@keyword"
                       asp-route-page="@(pageIndex + 1)">›</a>
                </li>
            </ul>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-set-default').forEach(btn => {
            btn.addEventListener('click', async () => {
                const productId = btn.dataset.productId;
                const unitId = btn.dataset.unitId;
                const token =
                    document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

                const res = await fetch(
                    `/ProductUnitMappings/SetDefault?productId=${productId}&unitId=${unitId}`,
                    { method: 'POST', headers: { 'RequestVerificationToken': token } }
                );

                const data = await res.json();
                if (data.success) location.reload();
            });
        });
    </script>
}