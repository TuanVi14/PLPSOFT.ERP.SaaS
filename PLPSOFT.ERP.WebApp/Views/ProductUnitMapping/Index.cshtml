@model IEnumerable<PLPSOFT.ERP.Domain.Entities.MasterData.ProductUnitMapping>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ProductId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UnitId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ConversionRate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsDefault)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ProductId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UnitId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ConversionRate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsDefault)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.UnitMappingId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.UnitMappingId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.UnitMappingId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
