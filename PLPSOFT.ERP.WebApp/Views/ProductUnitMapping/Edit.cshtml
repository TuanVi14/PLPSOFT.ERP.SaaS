@model PLPSOFT.ERP.WebApp.Models.ProductUnitMappingFormViewModel
@{
    ViewData["Title"] = "Sửa đơn vị tính";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index" asp-route-productId="@Model.OriginalProductID">Đơn vị tính</a>
        </li>
        <li class="breadcrumb-item active">Chỉnh sửa</li>
    </ol>
</nav>

<div class="card shadow-sm" style="max-width: 640px;">
    <div class="card-header bg-warning text-dark">
        <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa đơn vị tính
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="OriginalProductID" type="hidden" />
            <input asp-for="OriginalUnitID" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>


            <div class="mb-3">
                <label class="form-label fw-semibold">Sản phẩm</label>
                <input type="text" class="form-control" value="@Model.ProductDisplayName" readonly />
                <input asp-for="ProductID" type="hidden" />
            </div>


            <div class="mb-3">
                <label asp-for="UnitID" class="form-label fw-semibold"></label>
                <select asp-for="UnitID" asp-items="@Model.UnitOptions" class="form-select">
                    <option value="">-- Chọn đơn vị tính --</option>
                </select>
                <span asp-validation-for="UnitID" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConversionRate" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text">1 ÷</span>
                    <input asp-for="ConversionRate" type="number" min="0.000001" step="0.000001"
                           class="form-control" />
                </div>
                <span asp-validation-for="ConversionRate" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <div class="form-check form-switch">
                    <input asp-for="IsDefault" class="form-check-input" type="checkbox" role="switch" />
                    <label asp-for="IsDefault" class="form-check-label fw-semibold">Đơn vị mặc định</label>
                </div>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save me-1"></i> Cập nhật
                </button>
                <a asp-action="Index" asp-route-productId="@Model.OriginalProductID"
                   class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

