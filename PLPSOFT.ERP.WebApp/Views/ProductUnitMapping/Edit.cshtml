@model PLPSOFT.ERP.WebApp.Models.ProductUnitMappingFormViewModel

@{
    ViewData["Title"] = "Sửa đơn vị tính";
}

<!-- PAGE HEADER -->
<div class="plp-page-header">
    <div>
        <h1 class="plp-page-title">
            <i class="bi bi-pencil-square text-warning me-2"></i>
            Chỉnh sửa đơn vị tính
        </h1>

        <nav class="plp-breadcrumb">
            <a asp-action="Index"
               asp-route-productId="@Model.OriginalProductID">
                Đơn vị tính
            </a>
            <span> / </span>
            <span>Chỉnh sửa</span>
        </nav>
    </div>
</div>

<!-- FORM CARD -->
<div class="plp-card" style="max-width: 640px;">
    <div class="plp-card-header">
        <h2 class="plp-card-title">
            <i class="bi bi-rulers"></i>
            Thông tin đơn vị tính
        </h2>
    </div>

    <div class="plp-card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            <input asp-for="OriginalProductID" type="hidden" />
            <input asp-for="OriginalUnitID" type="hidden" />
            <input asp-for="ProductID" type="hidden" />

            <div asp-validation-summary="ModelOnly"
                 class="plp-validation mb-3"></div>

            <!-- Product (readonly) -->
            <div class="mb-3">
                <label class="plp-form-label">Sản phẩm</label>
                <input type="text"
                       class="form-control"
                       value="@Model.ProductDisplayName"
                       readonly />
            </div>

            <!-- Unit -->
            <div class="mb-3">
                <label asp-for="UnitID" class="plp-form-label"></label>
                <select asp-for="UnitID"
                        asp-items="@Model.UnitOptions"
                        class="form-select">
                    <option value="">-- Chọn đơn vị tính --</option>
                </select>
                <span asp-validation-for="UnitID"
                      class="text-danger small"></span>
            </div>

            <!-- Conversion Rate -->
            <div class="mb-3">
                <label asp-for="ConversionRate" class="plp-form-label"></label>

                <div class="input-group">
                    <span class="input-group-text">1 ÷</span>
                    <input asp-for="ConversionRate"
                           type="number"
                           min="0.000001"
                           step="0.000001"
                           class="form-control" />
                </div>

                <span asp-validation-for="ConversionRate"
                      class="text-danger small"></span>
            </div>

            <!-- Default -->
            <div class="form-check mb-4">
                <input asp-for="IsDefault"
                       class="form-check-input"
                       type="checkbox" />
                <label asp-for="IsDefault"
                       class="form-check-label">
                    Đơn vị mặc định
                </label>
            </div>

            <!-- ACTIONS -->
            <div class="d-flex justify-content-end gap-2">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save"></i> Cập nhật
                </button>

                <a asp-action="Index"
                   asp-route-productId="@Model.OriginalProductID"
                   class="btn btn-secondary">
                    Hủy
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}