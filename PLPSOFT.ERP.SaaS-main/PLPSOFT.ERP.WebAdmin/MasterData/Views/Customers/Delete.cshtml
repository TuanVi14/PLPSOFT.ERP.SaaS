@model src.PLPSOFT.ERP.Application.Features.Customers.DTOs.CustomerDto

@{
    ViewData["Title"] = "Delete Customer";
}

<h1>Delete Customer</h1>

<div>
    <h4>Are you sure you want to delete this customer?</h4>
    <dl class="row">
        <dt class="col-sm-2">Code</dt>
        <dd class="col-sm-10">@Model.Code</dd>
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
    </dl>

    <form asp-area="MasterData" asp-controller="Customers" asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-area="MasterData" asp-controller="Customers" asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
